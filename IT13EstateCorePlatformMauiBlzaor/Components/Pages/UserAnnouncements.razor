@page "/admin-announcements"
@layout UserLayout
@using Microsoft.Data.SqlClient
@using System.Data
@using IT13EstateCorePlatformMauiBlzaor.Data

@if (isChecking) {
    <p style="padding:40px;">Verifying module access...</p>
}
else if (!hasAccess) {
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 0vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1100px; width: 100%; height: 80%; margin-top: -100px;" />
    </div>
}
else {
    @* --- STATUS TOAST --- *@
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="status-toast">
            @statusMessage
        </div>
    }

    <div class="page-container">
        <header class="page-header">
            <div class="header-left">
                <h1>Announcements</h1>
                <p class="subtitle">Community updates for: <strong>@orgName</strong></p>
            </div>
            <div class="header-actions" >
                <button class="btn-post" @onclick="() => showModal = true">
                    <span class="plus-icon">+</span> Post Announcement
                </button>
                <input style="margin-top: 15px; margin-bottom: -20px;" type="text" placeholder="Search announcements..." @bind="searchTerm" @bind:event="oninput" class="search-input-sub" />
            </div>
        </header>

        <div class="announcement-feed">
            @if (!FilteredAnnouncements.Any())
            {
                <div class="empty-state">
                    <span class="empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                    </span>
                    <p>No announcements found.</p>
                </div>
            }
            else
            {
                @foreach (var item in FilteredAnnouncements)
                {
                    <div class="announcement-card @(item.IsUrgent ? "urgent-accent" : "standard-accent")">
                        <div class="card-top">
                            <div class="title-row">
                                <div class="title-group">
                                    <h2 class="card-title">@item.Title</h2>
                                    @if (item.IsUrgent)
                                    {
                                        <span class="badge-urgent">URGENT</span>
                                    }
                                </div>
                                <div class="date-info">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    @item.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            <p class="card-body-text">@item.Message</p>
                        </div>
                        
                        <div class="card-footer">
                            <span class="posted-by">Published by <strong>@item.PostedBy</strong></span>
                            <button class="btn-delete" @onclick='() => TriggerDeleteConfirm(item)'>Remove Post</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@* --- MODAL FOR NEW ANNOUNCEMENT --- *@
@if (showModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3 style="margin:0 0 10px 0;">New Announcement</h3>
            <p style="font-size:13px; color:#64748b; margin-bottom:20px;">This post will only be visible to members of <b>@orgName</b>.</p>
            
            <label>Title Headline</label>
            <input type="text" @bind="newTitle" class="form-input" placeholder="e.g. System Maintenance" />

            <label>Message Content</label>
            <textarea @bind="newMessage" class="form-input" rows="4" placeholder="Write the details here..."></textarea>

            <div class="urgent-toggle-row">
                <input type="checkbox" @bind="isUrgent" id="urgentCheck" />
                <label for="urgentCheck">Mark as Urgent Priority</label>
            </div>

            <div style="display:flex; gap:12px; margin-top:10px;">
                <button class="btn-post" style="flex:1;" @onclick="TriggerPostConfirm">Publish Now</button>
                <button class="btn-outline" style="flex:1;" @onclick="CloseModal">Cancel</button>
            </div>
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
    @if (showConfirmModal)
    {
        <div class="modal-backdrop" style="z-index: 10000;">
            <div class="modal-content" style="width: 400px; text-align: center;">
                <div class="confirm-icon">
                    @if (confirmType == "delete")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            <line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#14b8a6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 10"/>
                        </svg>
                    }
                </div>
                <h3 style="margin-top: 10px;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="btn-outline" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(confirmType == "delete" ? "btn-danger-action" : "btn-post")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "delete" ? "Yes, Remove" : "Yes, Publish")
                </button>
            </div>
        </div>
    </div>
}














@code {
    private bool isChecking = true, hasAccess = false, showModal = false, isUrgent = false;
    private string _conn = DbConfig.ConnectionString;
    private string orgName = "", newTitle = "", newMessage = "", statusMessage = "", searchTerm = "";
    private int myOrgId => Login.LoggedInOrgId; 

    private List<AnnouncementModel> announcements = new();

    // Confirmation State
    private bool showConfirmModal = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmType = ""; // "post" or "delete"
    private int? pendingDeleteId = null;

    // Logic for Filtering based on Search
    private IEnumerable<AnnouncementModel> FilteredAnnouncements => announcements.Where(a => 
        string.IsNullOrWhiteSpace(searchTerm) || 
        a.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
        a.Message.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() {
        hasAccess = await CheckAccess("Announcements");
        if (hasAccess) await LoadAnnouncements();
        isChecking = false;
    }

    private async Task LoadAnnouncements() {
        try {
            announcements.Clear();
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmdOrg = new("SELECT Name FROM Organizations WHERE OrganizationId = @oid", conn);
            cmdOrg.Parameters.AddWithValue("@oid", myOrgId);
            orgName = (await cmdOrg.ExecuteScalarAsync())?.ToString() ?? "Your Organization";

            string sql = "SELECT Id, Title, Message, IsUrgent, PostedBy, CreatedAt FROM Announcements WHERE OrganizationId = @oid ORDER BY CreatedAt DESC";
            using SqlCommand cmd = new(sql, conn); 
            cmd.Parameters.AddWithValue("@oid", myOrgId);
            using var reader = await cmd.ExecuteReaderAsync();
            while (await reader.ReadAsync()) {
                announcements.Add(new AnnouncementModel {
                    Id = reader.GetInt32(0), Title = reader.GetString(1), Message = reader.GetString(2),
                    IsUrgent = reader.GetBoolean(3), PostedBy = reader.GetString(4), CreatedAt = reader.GetDateTime(5)
                });
            }
        } catch { }
    }

    // --- Confirmation Trigger Logic ---

    private void TriggerPostConfirm() {
        if (string.IsNullOrEmpty(newTitle) || string.IsNullOrEmpty(newMessage)) return;
        confirmType = "post";
        confirmTitle = "Publish Announcement?";
        confirmMessage = $"Are you sure you want to broadcast '{newTitle}' to the entire community?";
        showConfirmModal = true;
    }

    private void TriggerDeleteConfirm(AnnouncementModel item) {
        pendingDeleteId = item.Id;
        confirmType = "delete";
        confirmTitle = "Remove Announcement?";
        confirmMessage = $"Are you sure you want to delete '{item.Title}'? This action cannot be undone and the post will vanish from the community feed.";
        showConfirmModal = true;
    }

    private async Task ExecuteConfirmedAction() {
        showConfirmModal = false;
        if (confirmType == "post") await PostAnnouncement();
        else if (confirmType == "delete" && pendingDeleteId.HasValue) await DeleteAnnouncement(pendingDeleteId.Value);
    }

    // --- Execution Logic ---

    private async Task PostAnnouncement() {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            string sql = "INSERT INTO Announcements (OrganizationId, Title, Message, IsUrgent, PostedBy) VALUES (@oid, @title, @msg, @urgent, @by)";
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@oid", myOrgId);
            cmd.Parameters.AddWithValue("@title", newTitle);
            cmd.Parameters.AddWithValue("@msg", newMessage);
            cmd.Parameters.AddWithValue("@urgent", isUrgent);
            cmd.Parameters.AddWithValue("@by", Login.LoggedInName ?? "Staff Admin");
            await cmd.ExecuteNonQueryAsync();
            
            ShowToast("Announcement published successfully!");
            CloseModal();
            await LoadAnnouncements();
        } catch { }
    }

    private async Task DeleteAnnouncement(int id) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmd = new("DELETE FROM Announcements WHERE Id = @id AND OrganizationId = @oid", conn);
            cmd.Parameters.AddWithValue("@id", id); 
            cmd.Parameters.AddWithValue("@oid", myOrgId);
            await cmd.ExecuteNonQueryAsync();
            ShowToast("Announcement removed.");
            await LoadAnnouncements();
        } catch { }
    }

    private void CloseModal() { showModal = false; newTitle = ""; newMessage = ""; isUrgent = false; }

    private void ShowToast(string msg) {
        statusMessage = msg;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => { statusMessage = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task<bool> CheckAccess(string module) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            string sql = "SELECT su.IsEnabled FROM Organizations o JOIN SystemUpdates su ON o.PlanType = su.PlanType WHERE o.OrganizationId = @oid AND su.ModuleName = @mod";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@oid", myOrgId); cmd.Parameters.AddWithValue("@mod", module);
            var res = await cmd.ExecuteScalarAsync(); return res != null && Convert.ToBoolean(res);
        } catch { return false; }
    }

    public class AnnouncementModel {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public bool IsUrgent { get; set; }
        public string PostedBy { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}















<style>
