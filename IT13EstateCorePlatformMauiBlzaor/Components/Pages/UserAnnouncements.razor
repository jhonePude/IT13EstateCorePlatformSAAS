    /* Custom Confirmation Styles */
    .confirm-icon { font-size: 32px; margin-bottom: 10px; }
    .btn-danger-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-danger-action:hover { background: #b91c1c; }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 9000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 500px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .form-input { width: 100%; padding: 12px; margin-top: 6px; margin-bottom: 18px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; box-sizing: border-box; }
    label { font-size: 13px; font-weight: 700; color: #374151; }
    .urgent-toggle-row { display:flex; align-items:center; gap:12px; margin-bottom:20px; background:#f9fafb; padding:12px; border-radius:8px; border: 1px solid #eee; }
    .btn-outline { background: white; border: 1px solid #e5e7eb; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer; }

    .status-toast { position: fixed; top: 20px; right: 20px; background: #111827; color: white; padding: 14px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; z-index: 99999; border-left: 4px solid #14b8a6; }
</style>```