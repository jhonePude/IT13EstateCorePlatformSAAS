@page "/admin-maintenance"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using IT13EstateCorePlatformMauiBlzaor.Data

@if (isChecking) { <p style="padding:40px;">Verifying module access...</p> }
else if (!hasAccess) {
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 0vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1100px; width: 100%; height: 80%; margin-top: -100px;" />
    </div>
}
else {
    <div class="maintenance-container">
        <header class="page-header">
            <div class="header-left">
                <h1>Maintenance Requests</h1>
                <p class="subtitle">
                    @if (DbConfig.IsOnline) {
                        <span class="conn-tag online"><span class="pulse-dot"></span> Online</span>
                    } else {
                        <span class="conn-tag offline">🌐 Offline</span>
                    }
                    • Managing requests for: <strong>@orgName</strong>
                </p>
            </div>
        </header>

        <div class="action-bar-top">
            <div class="search-wrapper-main">
                <input type="text" placeholder="Search title, tenant or unit..." @bind="searchTerm" @bind:event="oninput" class="search-input-modern" />
                <span class="search-icon-inside">🔍</span>
            </div>
        </div>

        <div class="maintenance-grid">
            @if (!FilteredRequests.Any())
            {
                <div class="empty-state">
                    <span class="empty-icon">🛠️</span>
                    <h3>No Requests Found</h3>
                    <p>Try searching for a different keyword or check back later.</p>
                </div>
            }
            else
            {
                @foreach (var req in FilteredRequests) {
                    <div class="maintenance-card">
                        <div class="card-top">
                            <div class="card-header-row">
                                <h3 class="card-title">@req.Title</h3>
                                <span class="priority-badge @req.Priority.ToLower()">@req.Priority</span>
                            </div>
                            
                            <p class="requested-by">@req.TenantName • @req.UnitNumber</p>
                            <p class="description">@req.Description</p>
                            
                            <div class="status-box @req.Status.Replace(" ", "-").ToLower()">
                                <span class="status-label-text">@req.Status</span>
                            </div>
                        </div>
                        <div class="card-action">
                            @if (req.Status == "PENDING") { 
                                <button class="btn-block-action btn-black" @onclick='() => TriggerConfirm(req, "IN PROGRESS")'>Assign Staff</button> 
                            }
                            else if (req.Status == "IN PROGRESS") { 
                                <button class="btn-block-action btn-green" @onclick='() => TriggerConfirm(req, "COMPLETED")'>Mark Completed</button> 
                            }
                            else { 
                                <div class="completed-banner">Resolved</div> 
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@if (showConfirmModal) {
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon-top">⚙️</div>
            <h3 style="margin-top: 10px; font-weight: 800;">Update Request?</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0;">Move status to <b>@pendingStatus</b>?</p>
            <div style="display:flex; gap:12px;">
                <button class="btn-outline-modal" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="btn-black-modal" style="flex:1;" @onclick="ExecuteConfirmed">Confirm Action</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isChecking = true, hasAccess = false, showConfirmModal = false;
    private string searchTerm = "", orgName = "", pendingStatus = "";
    private int pendingId;
    private List<MaintenanceModel> requests = new();
    private int myOrgId => Login.LoggedInOrgId;

    private IEnumerable<MaintenanceModel> FilteredRequests => requests.Where(r => r.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || r.TenantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() {
        hasAccess = await CheckAccess("Maintenance");
        if (hasAccess) {
            await LoadData();
            if (DbConfig.IsOnline) { _ = SyncOfflineMaintenance(); }
        }
        isChecking = false;
    }

    private async Task SyncOfflineMaintenance() {
        try {
            using SqlConnection local = new(DbConfig.GetLocalRaw); await local.OpenAsync();
            using var reader = await new SqlCommand($"SELECT Title, TenantId, Status, CreatedAt FROM MaintenanceRequests WHERE OrganizationId = {myOrgId}", local).ExecuteReaderAsync();
            using SqlConnection online = new(DbConfig.ConnectionString); await online.OpenAsync();
            while (await reader.ReadAsync()) {
                string sqlSync = @"
                    IF NOT EXISTS (SELECT 1 FROM MaintenanceRequests WHERE Title=@t AND TenantId=@tid AND CAST(CreatedAt as smalldatetime) = CAST(@ct as smalldatetime))
                    BEGIN
                        INSERT INTO MaintenanceRequests (OrganizationId, TenantId, Title, Description, Priority, Status, CreatedAt)
                        VALUES (@oid, @tid, @t, '', 'MEDIUM', @s, @ct)
                    END";
                using SqlCommand cmd = new(sqlSync, online);
                cmd.Parameters.AddWithValue("@oid", myOrgId);
                cmd.Parameters.AddWithValue("@t", reader.GetString(0));
                cmd.Parameters.AddWithValue("@tid", reader.GetInt32(1));
                cmd.Parameters.AddWithValue("@s", reader.GetString(2));
                cmd.Parameters.AddWithValue("@ct", reader.GetDateTime(3));
                await cmd.ExecuteNonQueryAsync();
            }
        } catch { }
    }

    private async Task LoadData() {
        try {
            requests.Clear();
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            orgName = (await new SqlCommand($"SELECT Name FROM Organizations WHERE OrganizationId = {myOrgId}", conn).ExecuteScalarAsync())?.ToString() ?? "Unknown";
            using var r = await new SqlCommand($@"SELECT m.Id, m.Title, m.Description, m.Priority, m.Status, t.FullName, t.UnitNumber FROM MaintenanceRequests m JOIN Tenants t ON m.TenantId = t.Id WHERE m.OrganizationId = {myOrgId} ORDER BY m.CreatedAt DESC", conn).ExecuteReaderAsync();
            while (await r.ReadAsync()) requests.Add(new MaintenanceModel { Id = r.GetInt32(0), Title = r.GetString(1), Description = r.IsDBNull(2) ? "" : r.GetString(2), Priority = r.GetString(3), Status = r.GetString(4), TenantName = r.GetString(5), UnitNumber = r.GetString(6) });
        } catch { }
    }

    private void TriggerConfirm(MaintenanceModel m, string s) { pendingId = m.Id; pendingStatus = s; showConfirmModal = true; }

    private async Task ExecuteConfirmed() {
        showConfirmModal = false;
        string sql = $@"UPDATE MaintenanceRequests SET Status = @s, ResolvedAt = {(pendingStatus == "COMPLETED" ? "GETDATE()" : "NULL")} WHERE Id = @id";
        await RunDual(sql);
        await LoadData();
    }

    private async Task RunDual(string sql) {
        await RunSql(DbConfig.GetLocalRaw, sql);
        if (DbConfig.IsOnline) await RunSql(DbConfig.ConnectionString, sql);
    }

    private async Task RunSql(string cs, string sql) {
        try {
            using SqlConnection conn = new(cs); await conn.OpenAsync();
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@s", pendingStatus); cmd.Parameters.AddWithValue("@id", pendingId);
            await cmd.ExecuteNonQueryAsync();
        } catch { }
    }

    private async Task<bool> CheckAccess(string m) {
        using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
        var res = await new SqlCommand($@"SELECT IsEnabled FROM SystemUpdates su JOIN Organizations o ON su.PlanType = o.PlanType WHERE o.OrganizationId = {myOrgId} AND su.ModuleName = 'Maintenance'", conn).ExecuteScalarAsync();
        return res != null && Convert.ToBoolean(res);
    }
    public class MaintenanceModel { public int Id; public string Title="", Description="", Priority="", Status="", TenantName="", UnitNumber=""; }
}

<style>
    /* Connection Tag Style */
    .conn-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; font-size: 13px; color: #10b981; }
    .conn-tag.offline { color: #6b7280; }
    .pulse-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; position: relative; }
    .pulse-dot::after { content: ""; position: absolute; top:0; left:0; right:0; bottom:0; background: inherit; border-radius: 50%; animation: pulse-dot-sync 1.5s infinite; }
    @@keyframes pulse-dot-sync { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

    .maintenance-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header { margin-bottom: 30px; }
    .page-header h1 { font-size: 36px; font-weight: 800; color: #111827; margin: 0; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }

    .action-bar-top { margin-bottom: 30px; display: flex; justify-content: flex-start; }
    .search-wrapper-main { position: relative; width: 400px; }
    .search-input-modern { width: 100%; padding: 14px 45px 14px 20px; border-radius: 12px; border: 1px solid #e5e7eb; outline: none; background: white; font-size: 14px; }
    .search-icon-inside { position: absolute; right: 20px; top: 14px; color: #94a3b8; }

    .maintenance-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
    
    .maintenance-card { background: white; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .maintenance-card:hover { transform: translateY(-4px); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
    
    .card-top { padding: 24px; flex-grow: 1; }
    .card-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .card-title { font-size: 20px; font-weight: 800; color: #111827; margin: 0; }
    
    .priority-badge { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .priority-badge.low { background: #f3f4f6; color: #64748b; }
    .priority-badge.medium { background: #fef3c7; color: #92400e; }
    .priority-badge.high { background: #fee2e2; color: #dc2626; }

    .requested-by { font-size: 14px; font-weight: 600; color: #4b5563; margin-bottom: 8px; }
    .description { font-size: 15px; color: #6b7280; line-height: 1.5; margin-bottom: 20px; min-height: 45px; }

    .status-box { font-size: 13px; font-weight: 800; text-transform: uppercase; }
    .status-box.pending { color: #f59e0b; }
    .status-box.in-progress { color: #3b82f6; }
    .status-box.completed { color: #10b981; }

    .card-action { padding: 0 24px 24px 24px; }
    .btn-block-action { width: 100%; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; border: none; transition: 0.2s; }
    .btn-black { background: #0f172a; color: white; }
    .btn-black:hover { background: #000; }
    .btn-green { background: #10b981; color: white; }
    .btn-green:hover { background: #059669; }

    .completed-banner { background: #f0fdf4; color: #10b981; padding: 12px; border-radius: 12px; text-align: center; font-weight: 800; font-size: 14px; }
    .empty-state { grid-column: 1 / -1; text-align: center; padding: 80px; background: white; border: 1px dashed #d1d5db; border-radius: 16px; color: #9ca3af; }

    /* Modal Styling */
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 10000; }
    .modal-content { background: white; padding: 40px; border-radius: 20px; width: 420px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .confirm-icon-top { font-size: 40px; margin-bottom: 15px; }
    .btn-outline-modal { background: white; border: 1px solid #e5e7eb; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .btn-black-modal { background: #0f172a; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; }
</style>