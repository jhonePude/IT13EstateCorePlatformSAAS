@page "/tenant-reservations"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using System.Globalization
@using IT13EstateCorePlatformMauiBlzaor.Data
@inject NavigationManager Nav

@if (isChecking)
{
    <p style="padding:40px; text-align:center; font-family:'Inter',sans-serif;">Verifying access...</p>
}
else if (!hasAccess)
{
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1000px; width: 100%; height: auto;" />
    </div>
}
else
{
    <div class="reservation-container">
        <header class="page-header">
            <div class="header-left">
                <h1>My Facility Bookings</h1>
                <p class="subtitle">@Login.LoggedInOrgName • Resident of @unitNumber</p>
            </div>

            <div class="header-right-group">
                <label for="tenantPicUpload" class="user-profile-btn">
                    <div class="profile-info" style="text-align: right;">
                        <span class="profile-name">@Login.LoggedInName</span>
                        <span class="profile-role">Resident</span>
                    </div>
                    <div class="avatar-circle">
                        @if (!string.IsNullOrEmpty(profilePicBase64))
                        {
                            <img src="@profilePicBase64" />
                        }
                        else
                        {
                            <span>@(string.IsNullOrEmpty(Login.LoggedInName) ? "T" : Login.LoggedInName.Substring(0, 1).ToUpper())</span>
                        }
                    </div>
                    <InputFile id="tenantPicUpload" OnChange="HandleFileSelected" style="display:none;" />
                </label>
            </div>
        </header>

        <div class="action-bar">
            <div class="search-box">
                <input type="text" placeholder="Search my bookings..." @bind="searchTerm" @bind:event="oninput" class="search-input" />
            </div>
            <button class="btn-primary" @onclick="() => showModal = true">+ Book a Facility</button>
        </div>

        @if (!FilteredReservations.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </span>
                <h3>No reservations found</h3>
                <p>Plan your next event by booking a community facility.</p>
            </div>
        }
        else
        {
            <div class="reservation-grid">
                @foreach (var res in FilteredReservations)
                {
                    <div class="reservation-card">
                        <div class="card-body">
                            <div class="facility-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                            </div>
                            <div class="details">
                                <h3 class="facility-name">@res.FacilityName</h3>
                                <span class="res-date">@res.ReservationDate.ToString("MMMM dd, yyyy | hh:mm tt")</span>
                                <div class="status-badge-container" style="margin-top:8px;">
                                    <span class="status-badge @res.Status.ToLower()">@res.Status</span>
                                </div>
                            </div>
                        </div>
                        @if (res.Status.ToUpper() == "PENDING") 
                        { 
                            <div class="card-footer">
                                <button class="btn-cancel" @onclick="() => TriggerCancelConfirm(res)">Cancel Request</button>
                            </div> 
                        }
                        else if (res.Status.ToUpper() == "CONFIRMED")
                        {
                            <div class="card-footer">
                                <span style="font-size: 11px; color: #10b981; font-weight:700;">✅ Approved Booking</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@* Booking Modal *@
@if (showModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>Facility Reservation</h3>
            <p style="font-size:13px; color:#6b7280; margin-bottom:20px;">Check facility availability for your preferred date.</p>
            <label>Select Facility</label>
            <select @bind="newRes.FacilityName" class="form-input">
                <option value="">-- Choose Facility --</option>
                <option value="Clubhouse">Clubhouse</option>
                <option value="Swimming Pool">Swimming Pool</option>
                <option value="Gym">Fitness Center/Gym</option>
            </select>
            <label>Date & Time</label>
            <input type="datetime-local" @bind="newRes.ReservationDate" class="form-input" />
            <div style="display:flex; gap:12px; margin-top:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="TriggerSubmitConfirm">Confirm</button>
                <button class="btn-outline" style="flex:1;" @onclick="() => showModal = false">Cancel</button>
            </div>
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon" style="font-size: 32px; margin-bottom: 10px;">@(confirmType == "cancel" ? "🗑️" : "📅")</div>
            <h3 style="margin-top: 10px; font-weight: 800;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="btn-outline" style="flex:1;" @onclick="() => showConfirmModal = false">Go Back</button>
                <button class="@(confirmType == "cancel" ? "btn-danger-action" : "btn-primary")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "cancel" ? "Confirm" : "Book Now")
                </button>
            </div>
        </div>
    </div>
}














@code {
    private bool isChecking = true, hasAccess = true, showModal = false;
    private string _conn = DbConfig.ConnectionString, unitNumber = "", searchTerm = "", profilePicBase64 = "";
    private List<ReservationModel> myReservations = new();
    private ReservationModel newRes = new() { ReservationDate = DateTime.Now.AddDays(1) };

    // Confirmation State
    private bool showConfirmModal = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmType = ""; // "submit" or "cancel"
    private int? pendingReservationId = null;

    private IEnumerable<ReservationModel> FilteredReservations => myReservations.Where(r => string.IsNullOrWhiteSpace(searchTerm) || r.FacilityName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() {
        if (Login.LoggedInTenantId == null) { Nav.NavigateTo("/login"); return; }
        hasAccess = await CheckModuleAccess("Reservations");
        if (hasAccess) { await LoadData(); await LoadProfilePic(); }
        isChecking = false;
    }

    private async Task<bool> CheckModuleAccess(string mod) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            string sql = @"SELECT su.IsEnabled FROM SystemUpdates su JOIN Organizations o ON su.PlanType = o.PlanType WHERE o.OrganizationId = @oid AND su.ModuleName = @mod";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId); cmd.Parameters.AddWithValue("@mod", mod);
            var res = await cmd.ExecuteScalarAsync(); return res != null && Convert.ToBoolean(res);
        } catch { return false; }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e) {
        var file = e.File; if (file == null) return;
        var resized = await file.RequestImageFileAsync("image/png", 300, 300);
        var buffer = new byte[resized.Size];
        using var stream = resized.OpenReadStream(); await stream.ReadAsync(buffer);
        profilePicBase64 = $"data:image/png;base64,{Convert.ToBase64String(buffer)}";
        using SqlConnection conn = new(_conn); await conn.OpenAsync();
        string sql = "UPDATE Tenants SET ProfilePicture = @pic WHERE Id = @tid";
        using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@pic", profilePicBase64); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
        await cmd.ExecuteNonQueryAsync();
    }

    private async Task LoadProfilePic() {
        using SqlConnection conn = new(_conn); await conn.OpenAsync();
        string sql = "SELECT ProfilePicture FROM Tenants WHERE Id = @tid";
        using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
        profilePicBase64 = (await cmd.ExecuteScalarAsync())?.ToString() ?? "";
    }

    private async Task LoadData() {
        try {
            myReservations.Clear();
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmdUnit = new("SELECT UnitNumber FROM Tenants WHERE Id = @tid", conn); cmdUnit.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
            unitNumber = (await cmdUnit.ExecuteScalarAsync())?.ToString() ?? "N/A";
            string sql = "SELECT Id, FacilityName, ReservationDate, Status FROM Reservations WHERE TenantId = @tid AND OrganizationId = @oid ORDER BY ReservationDate DESC";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId); cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId);
            using var reader = await cmd.ExecuteReaderAsync();
            while (await reader.ReadAsync()) myReservations.Add(new ReservationModel { Id = reader.GetInt32(0), FacilityName = reader.GetString(1), ReservationDate = reader.GetDateTime(2), Status = reader.GetString(3) });
        } catch { }
    }

    // --- Confirmation Trigger Logic ---

    private void TriggerSubmitConfirm() {
        if (string.IsNullOrWhiteSpace(newRes.FacilityName)) return;
        confirmType = "submit";
        confirmTitle = "Book Facility?";
        confirmMessage = $"Are you sure you want to reserve the {newRes.FacilityName} for {newRes.ReservationDate.ToString("MMM dd, hh:mm tt")}?";
        showConfirmModal = true;
    }

    private void TriggerCancelConfirm(ReservationModel res) {
        pendingReservationId = res.Id;
        confirmType = "cancel";
        confirmTitle = "Cancel Booking?";
        confirmMessage = $"Are you sure you want to withdraw your request for the {res.FacilityName}? This will free up the slot for other residents.";
        showConfirmModal = true;
    }

    private async Task ExecuteConfirmedAction() {
        showConfirmModal = false;
        if (confirmType == "submit") await SubmitReservation();
        else if (confirmType == "cancel" && pendingReservationId.HasValue) await CancelReservation(pendingReservationId.Value);
    }

    // --- Database Operations ---

    private async Task SubmitReservation() {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            string sql = "INSERT INTO Reservations (OrganizationId, TenantId, FacilityName, ReservationDate, Status, CreatedAt) VALUES (@oid, @tid, @f, @d, 'PENDING', GETDATE())";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId); cmd.Parameters.AddWithValue("@f", newRes.FacilityName); cmd.Parameters.AddWithValue("@d", newRes.ReservationDate);
            await cmd.ExecuteNonQueryAsync(); 
            showModal = false; 
            newRes = new ReservationModel { ReservationDate = DateTime.Now.AddDays(1) };
            await LoadData();
        } catch { }
    }

    private async Task CancelReservation(int id) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmd = new("DELETE FROM Reservations WHERE Id = @id AND TenantId = @tid AND Status = 'PENDING'"); 
            cmd.Parameters.AddWithValue("@id", id);
            cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
            await cmd.ExecuteNonQueryAsync(); 
            await LoadData();
        } catch { }
    }

    public class ReservationModel { public int Id { get; set; } public string FacilityName { get; set; } = ""; public DateTime ReservationDate { get; set; } public string Status { get; set; } = ""; }
}


















<style>
    .reservation-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .header-left h1 { font-size: 32px; font-weight: 800; color: #111827; margin: 0; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }

    .header-right-group { display: flex; align-items: center; gap: 20px; }
    .user-profile-btn { display: flex; align-items: center; gap: 12px; cursor: pointer; padding: 8px 15px; border-radius: 12px; background: white; border: 1px solid #e5e7eb; transition: 0.2s; }
    .user-profile-btn:hover { background: #f1f5f9; }
    .avatar-circle { width: 42px; height: 42px; background: #111827; color: white; border-radius: 50%; overflow: hidden; display: flex; align-items: center; justify-content: center; font-weight: 700; border: 2px solid #d4af37; }
    .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
    .profile-name { font-weight: 700; font-size: 14px; color: #111827; display: block; }
    .profile-role { font-size: 10px; color: #d4af37; text-transform: uppercase; font-weight: 800; }

    .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .search-input { padding: 12px 16px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; width: 300px; outline: none; background: white; }
    .btn-primary { background: #111827; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; font-size: 14px; }
    
    .reservation-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .reservation-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; display: flex; flex-direction: column; overflow: hidden; transition: 0.2s; }
    .card-body { padding: 20px; display: flex; gap: 15px; align-items: flex-start; }
    .facility-icon { width: 45px; height: 45px; background: #f1f5f9; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
    .facility-name { font-size: 16px; font-weight: 800; color: #111827; margin: 0; }
    .res-date { font-size: 12px; color: #64748b; font-weight: 600; margin-top: 4px; display: block; }
    .status-badge { font-size: 10px; font-weight: 800; padding: 4px 12px; border-radius: 50px; text-transform: uppercase; }
    .status-badge.confirmed { background: #dcfce7; color: #15803d; }
    .status-badge.pending { background: #fef3c7; color: #d97706; }
    .status-badge.rejected { background: #fee2e2; color: #dc2626; }

    .card-footer { padding: 12px 20px; background: #f9fafb; border-top: 1px solid #f3f4f6; border-radius: 0 0 12px 12px; }
    .btn-cancel { background: none; border: none; color: #dc2626; font-size: 11px; font-weight: 700; cursor: pointer; text-transform: uppercase; transition: 0.2s; }
    .btn-cancel:hover { opacity: 0.7; }

    /* Custom Confirmation Modal styles */
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 9000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .btn-danger-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-danger-action:hover { background: #b91c1c; }

    .empty-state { text-align: center; padding: 80px; background: white; border: 1px dashed #e5e7eb; border-radius: 16px; color: #9ca3af; grid-column: 1 / -1; }
    .form-input { width: 100%; padding: 12px; margin: 8px 0 18px 0; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; box-sizing: border-box; font-family: inherit; }
    label { font-size: 13px; font-weight: 700; color: #374151; }
    .btn-outline { background: white; border: 1px solid #e5e7eb; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer; }
</style>