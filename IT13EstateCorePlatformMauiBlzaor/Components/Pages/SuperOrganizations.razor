@page "/super-organizations"
@using Microsoft.Data.SqlClient
@using System.Data
@using IT13EstateCorePlatformMauiBlzaor.Data
@inject NavigationManager Nav

<div class="maintenance-container">
    <header class="page-header">
        <div class="header-left">
            <h1>Organizations</h1>
            <p class="subtitle">Platform Administration • Management Dashboard</p>
        </div>

       
    </header>

    <div class="action-bar">
        <div class="search-box">
            <input type="text" placeholder="Search organizations..." @bind="searchTerm" @bind:event="oninput" class="search-input" />
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">+ Add Organization</button>
    </div>

    @if (organizations == null)
    {
        <p style="padding:40px; text-align:center; font-family:'Inter',sans-serif;">Loading data...</p>
    }
    else if (!FilteredOrgs.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </div>
            <h3>No organizations found</h3>
            <p>Try a different search term or add a new property management company.</p>
        </div>
    }
    else
    {
        <div class="maintenance-grid">
            @foreach (var org in FilteredOrgs)
            {
                <div class="maintenance-card">
                    <div class="card-top">
                        <div class="title-group" style="display:flex; justify-content:space-between; align-items:start;">
                            <h3 class="card-title">@org.Name</h3>
                            <span class="priority-badge @(org.PlanType?.ToLower())">@org.PlanType</span>
                        </div>
                        <span class="request-date">Renewal: @org.Deadline.ToString("MMM dd, yyyy")</span>
                        
                        <div style="margin: 15px 0;">
                            <p class="description" style="margin: 2px 0;"><strong>Residents:</strong> @org.MaxResidents</p>
                            <p class="description" style="margin: 2px 0;"><strong>Staff:</strong> @org.MaxStaff</p>
                        </div>

                        <div class="status-indicator @(org.Status?.ToLower() == "active" ? "completed" : "pending")">
                            <span class="status-icon">
                                @if (org.Status?.ToLower() == "active")
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                }
                            </span>
                            <span class="status-text">@org.Status</span>
                        </div>
                    </div>
                    
                    <div class="card-footer" style="display:flex; gap:10px;">
                        <button class="btn-edit-small" @onclick="() => OpenEditModal(org)">Edit</button>
                        <button class="btn-delete-small" @onclick="() => ConfirmDelete(org)">Delete</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Main Add/Edit Modal *@
@if (showModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@(isEditMode ? "Edit Organization" : "New Organization")</h3>
            <p style="font-size:13px; color:#6b7280; margin-bottom:20px;">
                @(isEditMode ? "Update the organization's subscription and limits." : "Create a new organization and default admin account.")
            </p>

            <label>Organization Name</label>
            <input type="text" @bind="orgName" class="form-input" placeholder="e.g. BlueSky Properties" />

            <div style="display:flex; gap:15px;">
                <div style="flex:1;">
                    <label>Plan Type</label>
                    <select @bind="selectedPlan" class="form-input">
                        <option value="FREE">FREE</option>
                        <option value="BASIC">BASIC</option>
                        <option value="ENTERPRISE">ENTERPRISE</option>
                    </select>
                </div>
                <div style="flex:1;">
                    <label>Status</label>
                    <select @bind="selectedStatus" class="form-input">
                        <option value="ACTIVE">ACTIVE</option>
                        <option value="INACTIVE">INACTIVE</option>
                    </select>
                </div>
            </div>

            <label>Subscription Deadline</label>
            <input type="date" @bind="deadlineDate" class="form-input" />

            <div style="display:flex; gap:15px;">
                <div style="flex:1;">
                    <label>Max Residents</label>
                    <input type="number" @bind="residentsCount" class="form-input" />
                </div>
                <div style="flex:1;">
                    <label>Max Staff</label>
                    <input type="number" @bind="staffCount" class="form-input" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(saveError))
            {
                <p style="color:#dc2626; font-size:12px; margin-bottom:10px; font-weight:600;">@saveError</p>
            }

            <div style="display:flex; gap:12px; margin-top:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="ConfirmSave">Save Organization</button>
                <button class="btn-outline" style="flex:1;" @onclick="CloseModal">Cancel</button>
            </div>
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 1100;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon">
                @if (confirmType == "delete")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        <line x1="10" y1="11" x2="10" y2="17"/>
                        <line x1="14" y1="11" x2="14" y2="17"/>
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#14b8a6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                }
            </div>
            <h3 style="margin-top: 10px;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="btn-outline" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(confirmType == "delete" ? "btn-danger-action" : "btn-primary")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "delete" ? "Yes, Delete" : "Yes, Save")
                </button>
            </div>
        </div>
    </div>
}














@code {
    private List<OrganizationDisplayModel> organizations = new();
    private string searchTerm = "";
    private bool showModal = false;
    private bool isEditMode = false;
    private int currentEditingId = 0;
    private string saveError = "";

    // Confirmation State
    private bool showConfirmModal = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmType = ""; // "save" or "delete"
    private int? pendingDeleteId = null;

    // Form Fields
    private string orgName = "";
    private string selectedPlan = "FREE";
    private string selectedStatus = "ACTIVE";
    private DateTime deadlineDate = DateTime.Now.AddYears(1);
    private int residentsCount = 100;
    private int staffCount = 10;

    private string _connectionString = DbConfig.ConnectionString;

    private IEnumerable<OrganizationDisplayModel> FilteredOrgs => 
        organizations.Where(o => string.IsNullOrWhiteSpace(searchTerm) || o.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            var tempList = new List<OrganizationDisplayModel>();
            using SqlConnection conn = new(_connectionString);
            await conn.OpenAsync();
            string sql = "SELECT OrganizationId, Name, PlanType, Status, Deadline, MaxResidents, MaxStaff FROM Organizations ORDER BY Name ASC";
            using SqlCommand cmd = new(sql, conn);
            using var reader = await cmd.ExecuteReaderAsync();
            while (await reader.ReadAsync())
            {
                tempList.Add(new OrganizationDisplayModel {
                    OrganizationId = reader.GetInt32(0),
                    Name = reader.GetString(1),
                    PlanType = reader.IsDBNull(2) ? "FREE" : reader.GetString(2),
                    Status = reader.IsDBNull(3) ? "ACTIVE" : reader.GetString(3),
                    Deadline = reader.IsDBNull(4) ? DateTime.Now : reader.GetDateTime(4),
                    MaxResidents = reader.IsDBNull(5) ? 0 : reader.GetInt32(5),
                    MaxStaff = reader.IsDBNull(6) ? 0 : reader.GetInt32(6)
                });
            }
            organizations = tempList;
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void OpenAddModal()
    {
        isEditMode = false;
        ResetForm();
        showModal = true;
    }

    private void OpenEditModal(OrganizationDisplayModel org)
    {
        isEditMode = true;
        currentEditingId = org.OrganizationId;
        orgName = org.Name;
        selectedPlan = org.PlanType ?? "FREE";
        selectedStatus = org.Status ?? "ACTIVE";
        deadlineDate = org.Deadline;
        residentsCount = org.MaxResidents;
        staffCount = org.MaxStaff;
        saveError = "";
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    // --- Confirmation Logic ---

    private void ConfirmSave()
    {
        if (string.IsNullOrWhiteSpace(orgName)) { saveError = "Organization name is required."; return; }
        
        confirmType = "save";
        confirmTitle = isEditMode ? "Update Organization?" : "Create Organization?";
        confirmMessage = isEditMode 
            ? $"Save changes to {orgName}? This will update limits and status immediately." 
            : $"Register {orgName} as a new platform member? This will also create an admin account.";
        showConfirmModal = true;
    }

    private void ConfirmDelete(OrganizationDisplayModel org)
    {
        pendingDeleteId = org.OrganizationId;
        confirmType = "delete";
        confirmTitle = "Confirm Deletion";
        confirmMessage = $"Are you sure you want to delete {org.Name}? This will also delete all associated staff and user logins. This cannot be undone.";
        showConfirmModal = true;
    }

    private async Task ExecuteConfirmedAction()
    {
        showConfirmModal = false;
        if (confirmType == "save") await HandleSave();
        else if (confirmType == "delete" && pendingDeleteId.HasValue) await HandleDelete(pendingDeleteId.Value);
    }

    // --- Database Operations ---

    private async Task HandleSave()
    {
        try
        {
            using SqlConnection conn = new(_connectionString);
            await conn.OpenAsync();
            
            if (isEditMode)
            {
                string sql = @"UPDATE Organizations SET Name=@name, PlanType=@plan, Deadline=@deadline, Status=@status, MaxResidents=@res, MaxStaff=@staff WHERE OrganizationId=@id";
                using SqlCommand cmd = new(sql, conn);
                cmd.Parameters.AddWithValue("@name", orgName);
                cmd.Parameters.AddWithValue("@plan", selectedPlan);
                cmd.Parameters.AddWithValue("@deadline", deadlineDate);
                cmd.Parameters.AddWithValue("@status", selectedStatus);
                cmd.Parameters.AddWithValue("@res", residentsCount);
                cmd.Parameters.AddWithValue("@staff", staffCount);
                cmd.Parameters.AddWithValue("@id", currentEditingId);
                await cmd.ExecuteNonQueryAsync();
            }
            else
            {
                using var trans = conn.BeginTransaction();
                try {
                    string insOrg = @"INSERT INTO Organizations (Name, PlanType, Deadline, Status, MaxResidents, MaxStaff) 
                                     OUTPUT INSERTED.OrganizationId VALUES (@name, @plan, @deadline, @status, @res, @staff)";
                    int newId;
                    using (SqlCommand cmd = new(insOrg, conn, trans)) {
                        cmd.Parameters.AddWithValue("@name", orgName);
                        cmd.Parameters.AddWithValue("@plan", selectedPlan);
                        cmd.Parameters.AddWithValue("@deadline", deadlineDate);
                        cmd.Parameters.AddWithValue("@status", selectedStatus);
                        cmd.Parameters.AddWithValue("@res", residentsCount);
                        cmd.Parameters.AddWithValue("@staff", staffCount);
                        newId = (int)await cmd.ExecuteScalarAsync();
                    }

                    string adminUser = orgName.Replace(" ", "").ToLower() + "admin";
                    string insAdmin = @"INSERT INTO [Login] (Username, Password, FullName, Email, Role, IsActive, CreatedAt, OrganizationId)
                                       VALUES (@user, 'Admin123', @full, @email, 'Admin', 1, GETDATE(), @oid)";
                    using (SqlCommand cmd = new(insAdmin, conn, trans)) {
                        cmd.Parameters.AddWithValue("@user", adminUser);
                        cmd.Parameters.AddWithValue("@full", orgName + " Admin");
                        cmd.Parameters.AddWithValue("@email", adminUser + "@estate.com");
                        cmd.Parameters.AddWithValue("@oid", newId);
                        await cmd.ExecuteNonQueryAsync();
                    }
                    trans.Commit();
                } catch { trans.Rollback(); throw; }
            }
            showModal = false;
            await LoadData();
        }
        catch (Exception ex) { saveError = "Database error: " + ex.Message; }
    }

    private async Task HandleDelete(int id)
    {
        try {
            using SqlConnection conn = new(_connectionString);
            await conn.OpenAsync();
            using SqlCommand cmd1 = new("DELETE FROM [Login] WHERE OrganizationId = @id", conn);
            cmd1.Parameters.AddWithValue("@id", id);
            await cmd1.ExecuteNonQueryAsync();

            using SqlCommand cmd2 = new("DELETE FROM Organizations WHERE OrganizationId = @id", conn);
            cmd2.Parameters.AddWithValue("@id", id);
            await cmd2.ExecuteNonQueryAsync();
            await LoadData();
        } catch { }
    }

    private void ResetForm()
    {
        orgName = ""; selectedPlan = "FREE"; selectedStatus = "ACTIVE";
        deadlineDate = DateTime.Now.AddYears(1); residentsCount = 100; staffCount = 10; saveError = "";
    }

    public class OrganizationDisplayModel {
        public int OrganizationId { get; set; }
        public string Name { get; set; } = "";
        public string? PlanType { get; set; }
        public string? Status { get; set; }
        public DateTime Deadline { get; set; }
        public int MaxResidents { get; set; }
        public int MaxStaff { get; set; }
    }
}














<style>
    .maintenance-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .header-left h1 { font-size: 32px; font-weight: 800; color: #111827; margin: 0; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }

    .header-right-group { display: flex; align-items: center; gap: 20px; }
    .user-profile-btn { display: flex; align-items: center; gap: 12px; padding: 8px 15px; border-radius: 12px; background: white; border: 1px solid #e5e7eb; }
    .avatar-circle { width: 42px; height: 42px; background: #111827; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; border: 2px solid #d4af37; }
    .profile-name { font-weight: 700; font-size: 14px; color: #111827; display: block; }
    .profile-role { font-size: 10px; color: #d4af37; text-transform: uppercase; font-weight: 800; }

    .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .search-input { padding: 12px 16px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; width: 300px; outline: none; background: white; }
    .btn-primary { background: #111827; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; font-size: 14px; }
    .btn-primary:hover { opacity: 0.9; }

    .maintenance-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
    .maintenance-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; display: flex; flex-direction: column; transition: 0.2s; }
    .card-top { padding: 20px; flex-grow: 1; }
    .card-title { font-size: 16px; font-weight: 700; color: #111827; margin: 0; }
    .request-date { font-size: 11px; color: #94a3b8; font-weight: 600; text-transform: uppercase; margin-bottom: 10px; display: block; }
    .description { font-size: 13px; color: #4b5563; }
    
    .priority-badge { font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 50px; text-transform: uppercase; }
    .priority-badge.free { background: #f1f5f9; color: #64748b; }
    .priority-badge.basic { background: #111827; color: white; }
    .priority-badge.enterprise { background: #e0e7ff; color: #4338ca; border: 1px solid #c7d2fe; }

    .status-indicator { display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; margin-top: 15px; }
    .status-indicator.pending { color: #f59e0b; }
    .status-indicator.completed { color: #10b981; }

    .card-footer { padding: 15px 20px; background: #f9fafb; border-top: 1px solid #f3f4f6; border-radius: 0 0 12px 12px; }
    .btn-edit-small { background: #111827; color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; }
    .btn-delete-small { background: #fee2e2; color: #dc2626; border: none; padding: 6px 12px; border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; }

    /* Custom Confirm Styles */
    .confirm-icon { font-size: 32px; margin-bottom: 10px; }
    .btn-danger-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-danger-action:hover { background: #b91c1c; }

    .empty-state { text-align: center; padding: 80px; background: white; border: 1px dashed #e5e7eb; border-radius: 16px; color: #9ca3af; grid-column: 1 / -1; }
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .form-input { width: 100%; padding: 12px; margin: 8px 0 18px 0; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; box-sizing: border-box; font-family: inherit; }
    label { font-size: 13px; font-weight: 700; color: #374151; }
    .btn-outline { background: white; border: 1px solid #e5e7eb; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer; }
</style>