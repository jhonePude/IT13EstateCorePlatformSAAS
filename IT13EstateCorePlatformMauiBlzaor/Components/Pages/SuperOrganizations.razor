@page "/super-organizations"
@using Microsoft.Data.SqlClient
@using System.Data
@using IT13EstateCorePlatformMauiBlzaor.Data
@inject NavigationManager Nav

<div class="maintenance-container">
    <header class="page-header">
        <div class="header-left">
            <h1>Organizations</h1>
            <p class="subtitle">
                @if (DbConfig.IsOnline) {
                    <span class="conn-tag online"><span class="pulse-dot"></span> Online</span>
                } else {
                    <span class="conn-tag offline">🌐 Offline Mode</span>
                }
                • Platform Administration • Management Dashboard
            </p>
        </div>
    </header>

    @* --- TRANSACTIONAL SECTION --- *@
    <div class="table-card" style="margin-bottom: 30px; border: 2px solid #d4af37;">
        <div class="table-card-header" style="background: #fffbeb; color: #92400e; font-weight: 800;">
            Pending Upgrade Transactions
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Organization</th><th>Current Plan</th><th>Requested Plan</th><th>Date</th><th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (upgradeRequests == null || !upgradeRequests.Any()) {
                    <tr><td colspan="5" style="text-align:center; padding:20px; color:gray;">No pending transactions.</td></tr>
                } else {
                    @foreach (var req in upgradeRequests) {
                        <tr>
                            <td style="font-weight:700;">@req.OrgName</td>
                            <td>@req.CurrentPlan</td>
                            <td style="color: #14b8a6; font-weight: 800;">@req.RequestedPlan</td>
                            <td>@req.RequestedAt.ToString("MMM dd, yyyy")</td>
                            <td style="text-align: right;">
                                <button class="btn-approve" @onclick="() => OpenPaymentModal(req)">Approve Request</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="action-bar-container">
        <button class="btn-primary" @onclick="OpenAddModal">+ Add Organization</button>
        <div class="search-wrapper">
            <input type="text" placeholder="Search organizations..." @bind="searchTerm" @bind:event="oninput" class="search-input-modern" />
            <span class="search-icon-inside">🔍</span>
        </div>
    </div>

    <div class="maintenance-grid">
        @foreach (var org in FilteredOrgs) {
            <div class="maintenance-card">
                <div class="card-top">
                    <div class="title-group" style="display:flex; justify-content:space-between; align-items:start;">
                        <h3 class="card-title">@org.Name</h3>
                        <span class="priority-badge @(org.PlanType?.ToLower())">@org.PlanType</span>
                    </div>
                    <span class="request-date">Renewal: @org.Deadline.ToString("MMM dd, yyyy")</span>
                    <div style="margin: 15px 0;">
                        <p class="description"><strong>Residents:</strong> @org.MaxResidents</p>
                        <p class="description"><strong>Staff:</strong> @org.MaxStaff</p>
                    </div>
                    <div class="status-indicator @(org.Status?.ToLower() == "active" ? "completed" : "pending")">
                        <span class="status-text">@org.Status</span>
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn-edit-small" @onclick="() => OpenEditModal(org)">Edit</button>
                    <button class="btn-delete-small" @onclick="() => TriggerDeleteConfirm(org)">Delete</button>
                </div>
            </div>
        }
    </div>
</div>

@* --- DATA ENTRY MODAL --- *@
@if (showModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@(isEditMode ? "Edit Organization" : "New Organization")</h3>
            
            <label>Organization Name</label>
            <input type="text" @bind="orgName" class="form-input" placeholder="e.g. Skyline" />
            
            <div style="display:flex; gap:15px;">
                <div style="flex:1;"><label>Max Residents</label><input type="number" @bind="residentsCount" class="form-input" /></div>
                <div style="flex:1;"><label>Max Staff</label><input type="number" @bind="staffCount" class="form-input" /></div>
            </div>

            <div style="display:flex; gap:15px;">
                <div style="flex:1;"><label>Status</label>
                    <select @bind="selectedStatus" class="form-input">
                        <option value="ACTIVE">ACTIVE</option>
                        <option value="INACTIVE">INACTIVE</option>
                    </select>
                </div>
                <div style="flex:1;"><label>Deadline</label><input type="date" @bind="deadlineDate" class="form-input" /></div>
            </div>

            @if (!isEditMode) {
                <div style="background: #f0fdfa; border: 1px solid #99f6e4; padding: 12px; border-radius: 8px; margin-bottom: 10px;">
                    <p style="font-size: 11px; font-weight: 800; color: #0f766e; margin: 0 0 4px 0;">✨ AUTO-ACCOUNT ENABLED</p>
                    <p style="font-size: 12px; color: #115e59; margin: 0;">User: [name]admin | Pass: admin123</p>
                </div>
            }

            <div style="display:flex; gap:12px; margin-top:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="TriggerSaveConfirm">Save Record</button>
                <button class="btn-outline" style="flex:1;" @onclick="CloseModal">Cancel</button>
            </div>
        </div>
    </div>
}

@* --- CUSTOM CONFIRMATION MODAL (SAVE/DELETE) --- *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon" style="font-size: 32px; margin-bottom: 10px;">@(confirmType == "delete" ? "🗑️" : "💾")</div>
            <h3 style="margin-top: 10px; font-weight: 800;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="btn-outline" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(confirmType == "delete" ? "btn-delete-action" : "btn-primary")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "delete" ? "Yes, Delete" : "Yes, Save")
                </button>
            </div>
        </div>
    </div>
}














@code {
    private List<OrganizationDisplayModel> organizations = new();
    private List<UpgradeReqModel> upgradeRequests = new();
    private string searchTerm = "", orgName = "", selectedStatus = "ACTIVE";
    private bool showModal = false, isEditMode = false, showConfirmModal = false;
    private string confirmTitle = "", confirmMessage = "", confirmType = "";
    private int currentEditingId = 0, residentsCount = 50, staffCount = 5;
    private DateTime deadlineDate = DateTime.Now.AddYears(1);
    private OrganizationDisplayModel? pendingDeleteOrg;

    private IEnumerable<OrganizationDisplayModel> FilteredOrgs => organizations.Where(o => string.IsNullOrWhiteSpace(searchTerm) || o.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() { await LoadData(); }

    private async Task LoadData() {
        try {
            organizations.Clear();
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            using var r = await new SqlCommand("SELECT OrganizationId, Name, PlanType, Status, Deadline, MaxResidents, MaxStaff FROM Organizations ORDER BY Name ASC", conn).ExecuteReaderAsync();
            while (await r.ReadAsync()) organizations.Add(new OrganizationDisplayModel { 
                OrganizationId = r.GetInt32(0), Name = r.GetString(1), PlanType = r.IsDBNull(2) ? "FREE" : r.GetString(2), 
                Status = r.GetString(3), Deadline = r.GetDateTime(4), MaxResidents = r.GetInt32(5), MaxStaff = r.GetInt32(6) 
            });
        } catch { }
    }

    private void OpenAddModal() { isEditMode = false; orgName = ""; residentsCount = 50; staffCount = 5; showModal = true; }
    private void OpenEditModal(OrganizationDisplayModel org) { isEditMode = true; currentEditingId = org.OrganizationId; orgName = org.Name; selectedStatus = org.Status; deadlineDate = org.Deadline; residentsCount = org.MaxResidents; staffCount = org.MaxStaff; showModal = true; }
    private void CloseModal() => showModal = false;

    // --- Confirmation Triggers ---
    private void TriggerSaveConfirm() {
        if (string.IsNullOrWhiteSpace(orgName)) return;
        confirmType = "save";
        confirmTitle = isEditMode ? "Update Organization?" : "Add New Organization?";
        confirmMessage = isEditMode ? $"Save changes for {orgName}?" : $"Create {orgName} and generate admin account?";
        showConfirmModal = true;
    }

    private void TriggerDeleteConfirm(OrganizationDisplayModel org) {
        pendingDeleteOrg = org;
        confirmType = "delete";
        confirmTitle = "Delete Organization?";
        confirmMessage = $"Are you sure you want to remove {org.Name}? This will delete all residents and admin data linked to it.";
        showConfirmModal = true;
    }

    private async Task ExecuteConfirmedAction() {
        showConfirmModal = false;
        if (confirmType == "save") await SaveProcess();
        else if (confirmType == "delete" && pendingDeleteOrg != null) await DeleteProcess(pendingDeleteOrg);
    }

    private async Task SaveProcess() {
        await ExecuteDualSave(DbConfig.GetLocalRaw);
        if (DbConfig.IsOnline) await ExecuteDualSave(DbConfig.ConnectionString);
        showModal = false; await LoadData();
    }

    private async Task ExecuteDualSave(string connString) {
        try {
            using SqlConnection conn = new(connString); await conn.OpenAsync();
            string sql = isEditMode ? "UPDATE Organizations SET Name=@n, Status=@s, Deadline=@d, MaxResidents=@res, MaxStaff=@stf WHERE OrganizationId=@id" :
                "INSERT INTO Organizations (Name, PlanType, Deadline, Status, MaxResidents, MaxStaff) OUTPUT INSERTED.OrganizationId VALUES (@n, 'FREE', @d, @s, @res, @stf)";
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@n", orgName); cmd.Parameters.AddWithValue("@s", selectedStatus); cmd.Parameters.AddWithValue("@d", deadlineDate);
            cmd.Parameters.AddWithValue("@res", residentsCount); cmd.Parameters.AddWithValue("@stf", staffCount);
            if (isEditMode) cmd.Parameters.AddWithValue("@id", currentEditingId);

            var resId = await cmd.ExecuteScalarAsync();
            if (!isEditMode && resId != null) {
                string clean = orgName.Replace(" ", "").ToLower();
                string log = $@"INSERT INTO [Login] (Username, Password, FullName, Email, Role, IsActive, OrganizationId) 
                                VALUES ('{clean}admin', 'admin123', '{orgName} Admin', '{clean}@@estatecore.com', 'Admin', 1, {resId})";
                await new SqlCommand(log, conn).ExecuteNonQueryAsync();
            }
        } catch { }
    }

    private async Task DeleteProcess(OrganizationDisplayModel org) {
        using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
        await new SqlCommand($"DELETE FROM [Login] WHERE OrganizationId={org.OrganizationId}; DELETE FROM Organizations WHERE OrganizationId={org.OrganizationId}", conn).ExecuteNonQueryAsync();
        await LoadData();
    }

    // Methods for upgrade transactions...
    private void OpenPaymentModal(UpgradeReqModel req) { }
    private async Task LoadUpgradeRequests() { }

    public class OrganizationDisplayModel { public int OrganizationId { get; set; } public string Name { get; set; } = ""; public string? PlanType { get; set; } public string Status { get; set; } = ""; public DateTime Deadline { get; set; } public int MaxResidents { get; set; } public int MaxStaff { get; set; } }
    public class UpgradeReqModel { public int Id { get; set; } public int OrgId { get; set; } public string OrgName { get; set; } = ""; public string CurrentPlan { get; set; } = ""; public string RequestedPlan { get; set; } = ""; public DateTime RequestedAt { get; set; } }
}













<style>
    /* Connection Pulsating Status */
    .conn-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; font-size: 13px; }
    .conn-tag.online { color: #10b981; }
    .conn-tag.offline { color: #6b7280; }
    .pulse-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; position: relative; }
    .pulse-dot::after { content: ""; position: absolute; top:0; left:0; right:0; bottom:0; background: inherit; border-radius: 50%; animation: pulse 1.5s infinite; }
    @@keyframes pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

    /* Restoration of Original Design */
    .maintenance-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header h1 { font-size: 32px; font-weight: 800; color: #111827; margin:0; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }
    .action-bar-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 20px; }
    .search-input-modern { width: 100%; padding: 12px 40px 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; background: white; outline: none; }
    .search-wrapper { position: relative; width: 350px; }
    .search-icon-inside { position: absolute; right: 15px; top: 12px; color: #94a3b8; }
    .table-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
    .table-card-header { padding: 15px 20px; font-size: 14px; border-bottom: 1px solid #f3f4f6; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { background: #f9fafb; padding: 12px 20px; font-size: 11px; text-align: left; text-transform: uppercase; font-weight: 800; }
    .data-table td { padding: 12px 20px; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    .maintenance-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
    .maintenance-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; transition: 0.2s; }
    .card-footer { padding: 15px 20px; background: #f9fafb; border-top: 1px solid #f3f4f6; display: flex; gap: 10px; margin: 20px -20px -20px -20px; border-radius: 0 0 12px 12px; }
    .btn-edit-small, .btn-delete-small { flex: 1; padding: 8px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-edit-small { background: white; border: 1px solid #e5e7eb; color: #111827; }
    .btn-delete-small { background: #fee2e2; border: 1px solid #fecaca; color: #dc2626; }
    .btn-delete-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .priority-badge { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; }
    .priority-badge.basic { background: #fffbeb; color: #92400e; border: 1px solid #fcd34d; }
    .priority-badge.free { background: #f1f5f9; color: #64748b; }
    .priority-badge.enterprise { background: #e0e7ff; color: #4338ca; border: 1px solid #c7d2fe; }
    .btn-primary { background: #111827; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 700; cursor: pointer; }
    .btn-approve { background: #10b981; color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; }
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .form-input { width: 100%; padding: 10px; margin: 8px 0 15px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
    .btn-outline { background: white; border: 1px solid #ddd; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 700; }
    label { font-size: 12px; font-weight: 700; color: #374151; }
</style>