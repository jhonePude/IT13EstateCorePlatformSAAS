@page "/admin-tenants"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using System.Globalization
@using IT13EstateCorePlatformMauiBlzaor.Data

@if (isChecking) {
    <p style="padding:40px;">Verifying module access...</p>
}
else if (!hasAccess) {
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 0vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1100px; width: 100%; height: 80%; margin-top: -100px;" />
    </div>
}
else {
    <div class="page-container">
        <header class="page-header">
            <div class="header-left">
                <h1>Tenant Management</h1>
                <p class="subtitle">
                    @if (DbConfig.IsOnline) {
                        <span class="conn-tag online"><span class="pulse-dot"></span> Online</span>
                    } else {
                        <span class="conn-tag offline">🌐 Offline</span>
                    }
                    • Resident Directory for: <strong>@orgName</strong>
                </p>
            </div>
            <button class="btn-primary" @onclick="OpenCreateModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Add Tenant
            </button>
        </header>

        <div class="stats-row">
            <div class="stat-item" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); border-color: #c7d2fe;">
                <span class="stat-label" style="color: #4338ca;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> Total Tenants / Max Residents</span>
                <span class="stat-value" style="color: #3730a3;">@tenants.Count / @maxResidents</span>
            </div>
            <div class="stat-item" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-color: #6ee7b7;">
                <span class="stat-label" style="color: #065f46;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Active Residents</span>
                <span class="stat-value" style="color: #065f46;">@tenants.Count(t => t.Status == "Active")</span>
            </div>
            <div class="stat-item" style="background: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%); border-color: #fecdd3;">
                <span class="stat-label" style="color: #9f1239;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg> Inactive</span>
                <span class="stat-value" style="color: #be123c;">@tenants.Count(t => t.Status == "Inactive")</span>
            </div>
        </div>

        <div class="table-card">
            <div class="table-header">
                <span>Resident List</span>
                <input type="text" placeholder="Search name or unit..." class="search-input" @bind="searchTerm" @bind:event="oninput" />
            </div>
            <table class="data-table">
                <thead><tr><th>Full Name</th><th>Unit</th><th>Contact (Login User)</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var t in FilteredTenants) {
                        <tr><td><strong>@t.FullName</strong></td><td>@t.UnitNumber</td><td>@t.Email <br/> <small>@t.PhoneNumber</small></td><td><span class="status-pill @t.Status.ToLower()">@t.Status</span></td><td><div style="display:flex; gap:5px;"><button class="action-btn" @onclick="() => OpenEditModal(t)">Edit</button><button class="action-btn delete" @onclick="() => ConfirmDelete(t)">Delete</button></div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (showModal) {
    <div class="modal-backdrop"><div class="modal-content">
        <h3>@(isEditing ? "Edit Tenant" : "Add New Tenant")</h3><hr />
        @if (!string.IsNullOrEmpty(errorMsg)) { <div style="background: #fee2e2; color: #dc2626; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">⚠️ @errorMsg</div> }
        @if (!isEditing) { <div style="background: #e6fffa; color: #059669; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 12px;">🔑 Password: <strong>Tenant123</strong></div> }
        <label>Full Name</label><input type="text" @bind="newTenant.FullName" class="form-input" /><label>Unit Number</label><input type="text" @bind="newTenant.UnitNumber" class="form-input" /><label>Email</label><input type="email" @bind="newTenant.Email" class="form-input" /><label>Phone</label><input type="text" @bind="newTenant.PhoneNumber" class="form-input" /><label>Status</label><select @bind="newTenant.Status" class="form-input"><option value="Active">Active</option><option value="Inactive">Inactive</option></select>
        <div style="margin-top:20px; display:flex; gap:10px; justify-content: flex-end;"><button class="btn-primary" @onclick="TriggerSaveConfirm">Save Record</button><button class="action-btn" @onclick="CloseModal">Cancel</button></div>
    </div></div>
}

@if (showConfirmModal) {
    <div class="modal-backdrop" style="z-index: 10000;"><div class="modal-content" style="text-align: center;"><div class="confirm-icon">@(confirmType == "delete" ? "🗑️" : "💾")</div><h3 style="font-weight: 800;">@confirmTitle</h3><p>@confirmMessage</p><div style="display:flex; gap:12px;"><button class="action-btn" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button><button class="@(confirmType == "delete" ? "btn-danger-action" : "btn-primary")" style="flex:1;" @onclick="ExecuteConfirmedAction">Confirm</button></div></div></div>
}














@code {
    private bool isChecking = true, hasAccess = false, showModal = false, isEditing = false, showConfirmModal = false;
    private string searchTerm = "", orgName = "", errorMsg = "", confirmTitle = "", confirmMessage = "", confirmType = "";
    private int myOrgId => Login.LoggedInOrgId; private int maxResidents = 0;
    private List<TenantModel> tenants = new(); private TenantModel newTenant = new();
    private TenantModel? pendingDeleteTenant;

    private IEnumerable<TenantModel> FilteredTenants => tenants.Where(t => t.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || t.UnitNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() {
        hasAccess = await CheckAccess("Tenants");
        if (hasAccess) { 
            await LoadData(); 
            // [ CATCH-UP SYNC LOGIC ]
            if (DbConfig.IsOnline) { _ = SyncTenants(); }
        }
        isChecking = false;
    }

    private async Task SyncTenants() {
        try {
            using SqlConnection local = new(DbConfig.GetLocalRaw); await local.OpenAsync();
            using var reader = await new SqlCommand($"SELECT FullName, Email, PhoneNumber, UnitNumber, Status FROM Tenants WHERE OrganizationId = {myOrgId}", local).ExecuteReaderAsync();
            using SqlConnection online = new(DbConfig.ConnectionString); await online.OpenAsync();
            while (await reader.ReadAsync()) {
                string sql = @"IF NOT EXISTS (SELECT 1 FROM Tenants WHERE Email = @e AND OrganizationId = @oid)
                               INSERT INTO Tenants (OrganizationId, FullName, Email, PhoneNumber, UnitNumber, Status, [Password])
                               VALUES (@oid, @n, @e, @p, @u, @s, 'Tenant123')";
                using SqlCommand cmd = new(sql, online);
                cmd.Parameters.AddWithValue("@oid", myOrgId); cmd.Parameters.AddWithValue("@n", reader.GetString(0));
                cmd.Parameters.AddWithValue("@e", reader.GetString(1)); cmd.Parameters.AddWithValue("@p", reader.GetString(2));
                cmd.Parameters.AddWithValue("@u", reader.GetString(3)); cmd.Parameters.AddWithValue("@s", reader.GetString(4));
                await cmd.ExecuteNonQueryAsync();
            }
        } catch { }
    }

    private async Task LoadData() {
        try {
            tenants.Clear();
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            using var rOrg = await new SqlCommand($"SELECT Name, MaxResidents FROM Organizations WHERE OrganizationId = {myOrgId}", conn).ExecuteReaderAsync();
            if (await rOrg.ReadAsync()) { orgName = rOrg.GetString(0); maxResidents = rOrg.GetInt32(1); }
            rOrg.Close();
            using var r = await new SqlCommand($"SELECT Id, FullName, Email, PhoneNumber, UnitNumber, Status FROM Tenants WHERE OrganizationId = {myOrgId} ORDER BY FullName", conn).ExecuteReaderAsync();
            while (await r.ReadAsync()) tenants.Add(new TenantModel { Id = r.GetInt32(0), FullName = r.GetString(1), Email = r.IsDBNull(2) ? "" : r.GetString(2), PhoneNumber = r.IsDBNull(3) ? "" : r.GetString(3), UnitNumber = r.GetString(4), Status = r.GetString(5) });
        } catch {}
    }

    private void TriggerSaveConfirm() { confirmType = "save"; confirmTitle = isEditing ? "Update?" : "Add?"; confirmMessage = "Save Record?"; showConfirmModal = true; }
    private void ConfirmDelete(TenantModel t) { pendingDeleteTenant = t; confirmType = "delete"; confirmTitle = "Delete?"; confirmMessage = $"Remove {t.FullName}?"; showConfirmModal = true; }

    private async Task ExecuteConfirmedAction() {
        showConfirmModal = false;
        string sql = isEditing ? "UPDATE Tenants SET FullName=@n, Email=@e, PhoneNumber=@p, UnitNumber=@u, Status=@s WHERE Id=@id" :
                                "INSERT INTO Tenants (OrganizationId, FullName, Email, PhoneNumber, UnitNumber, Status, [Password]) VALUES (@oid, @n, @e, @p, @u, @s, 'Tenant123')";
        if (confirmType == "delete") sql = "DELETE FROM Tenants WHERE Id=@id";
        
        // [ DUAL WRITE LOGIC ]
        await RunSql(DbConfig.GetLocalRaw, sql); // Always Save Local
        if (DbConfig.IsOnline) { await RunSql(DbConfig.ConnectionString, sql); } // Mirror to Cloud
        
        showModal = false; await LoadData();
    }

    private async Task RunSql(string cs, string sql) {
        try {
            using SqlConnection conn = new(cs); await conn.OpenAsync();
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@n", newTenant.FullName); cmd.Parameters.AddWithValue("@e", newTenant.Email);
            cmd.Parameters.AddWithValue("@p", newTenant.PhoneNumber ?? ""); cmd.Parameters.AddWithValue("@u", newTenant.UnitNumber);
            cmd.Parameters.AddWithValue("@s", newTenant.Status); cmd.Parameters.AddWithValue("@oid", myOrgId);
            if (isEditing || confirmType == "delete") cmd.Parameters.AddWithValue("@id", isEditing ? newTenant.Id : pendingDeleteTenant?.Id);
            await cmd.ExecuteNonQueryAsync();
        } catch { }
    }

    private async Task<bool> CheckAccess(string m) {
        using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
        var res = await new SqlCommand($@"SELECT IsEnabled FROM SystemUpdates su JOIN Organizations o ON su.PlanType = o.PlanType WHERE o.OrganizationId = {myOrgId} AND su.ModuleName = '{m}'", conn).ExecuteScalarAsync();
        return res != null && Convert.ToBoolean(res);
    }
    private void OpenCreateModal() { isEditing = false; newTenant = new TenantModel { Status = "Active" }; showModal = true; }
    private void OpenEditModal(TenantModel t) { isEditing = true; newTenant = t; showModal = true; }
    private void CloseModal() => showModal = false;
    public class TenantModel { public int Id; public string FullName="", Email="", PhoneNumber="", UnitNumber="", Status="Active"; }
}










<style>
    .conn-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; font-size: 13px; color: #10b981; }
    .conn-tag.offline { color: #6b7280; }
    .pulse-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; position: relative; }
    .pulse-dot::after { content: ""; position: absolute; top:0; left:0; right:0; bottom:0; background: inherit; border-radius: 50%; animation: pulse-dot-anim-t 1.5s infinite; }
    @@keyframes pulse-dot-anim-t { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

    .page-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
    .page-header h1 { font-size: 32px; font-weight: 800; color: #111827; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }
    .btn-primary { background: #111827; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px; }
    .stat-item { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; }
    .stat-value { font-size: 24px; font-weight: 700; color: #111827; display: block; }
    .table-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
    .table-header { display: flex; justify-content: space-between; padding: 20px; border-bottom: 1px solid #f3f4f6; }
    .search-input { padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 6px; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th, .data-table td { padding: 16px 20px; text-align: left; border-bottom: 1px solid #f3f4f6; }
    .status-pill { padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .status-pill.active { background: #d1fae5; color: #059669; }
    .action-btn { background: white; border: 1px solid #e5e7eb; padding: 6px 14px; border-radius: 6px; cursor: pointer; }
    .btn-danger-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; }
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 9000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; }
    .form-input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #e5e7eb; border-radius: 8px; }
</style>