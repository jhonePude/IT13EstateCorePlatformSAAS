@page "/admin-tenants"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using System.Globalization
@using IT13EstateCorePlatformMauiBlzaor.Data

@if (isChecking) {
    <p style="padding:40px;">Verifying module access...</p>
}
else if (!hasAccess) {
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 0vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1100px; width: 100%; height: 80%; margin-top: -100px;" />
    </div>
}
else {
    <div class="page-container">
        <header class="page-header">
            <div class="header-left">
                <h1>Tenant Management</h1>
                <p class="subtitle">Resident Directory for: <strong>@orgName</strong></p>
            </div>
            <button class="btn-primary" @onclick="OpenCreateModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="8.5" cy="7" r="4"/>
                    <line x1="20" y1="8" x2="20" y2="14"/>
                    <line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Add Tenant
            </button>
        </header>

        <div class="stats-row">
            <div class="stat-item" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); border-color: #c7d2fe;">
                <span class="stat-label" style="color: #4338ca;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> Total Tenants / Max Residents</span>
                <span class="stat-value" style="color: #3730a3;">@tenants.Count / @maxResidents</span>
            </div>
            <div class="stat-item" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-color: #6ee7b7;">
                <span class="stat-label" style="color: #047857;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Active Residents</span>
                <span class="stat-value" style="color: #065f46;">@tenants.Count(t => t.Status == "Active")</span>
            </div>
            <div class="stat-item" style="background: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%); border-color: #fecdd3;">
                <span class="stat-label" style="color: #9f1239;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg> Inactive</span>
                <span class="stat-value" style="color: #be123c;">@tenants.Count(t => t.Status == "Inactive")</span>
            </div>
        </div>

        <div class="table-card">
            <div class="table-header">
                <span>Resident List</span>
                <input type="text" placeholder="Search name or unit..." class="search-input" @bind="searchTerm" @bind:event="oninput" />
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Unit</th>
                        <th>Contact (Login User)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in FilteredTenants) {
                        <tr>
                            <td><strong>@t.FullName</strong></td>
                            <td>@t.UnitNumber</td>
                            <td>@t.Email <br/> <small>@t.PhoneNumber</small></td>
                            <td><span class="status-pill @t.Status.ToLower()">@t.Status</span></td>
                            <td>
                                <div style="display:flex; gap:5px;">
                                    <button class="action-btn" @onclick="() => OpenEditModal(t)">Edit</button>
                                    <button class="action-btn delete" @onclick="() => ConfirmDelete(t)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (showModal) {
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>@(isEditing ? "Edit Tenant" : "Add New Tenant")</h3>
            <hr />
            @if (!string.IsNullOrEmpty(errorMsg)) {
                <div style="background: #fee2e2; color: #dc2626; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">⚠️ @errorMsg</div>
            }
            @if (!isEditing) {
                <div style="background: #e6fffa; color: #059669; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 12px;">
                    🔑 Login Password will be: <strong>Tenant123</strong>
                </div>
            }
            <label>Full Name</label><input type="text" @bind="newTenant.FullName" class="form-input" />
            <label>Unit Number</label><input type="text" @bind="newTenant.UnitNumber" class="form-input" />
            <label>Email (Login Username)</label><input type="email" @bind="newTenant.Email" class="form-input" />
            <label>Phone</label><input type="text" @bind="newTenant.PhoneNumber" class="form-input" />
            <label>Status</label><select @bind="newTenant.Status" class="form-input"><option value="Active">Active</option><option value="Inactive">Inactive</option></select>
            <div style="margin-top:20px; display:flex; gap:10px; justify-content: flex-end;">
                <button class="btn-primary" @onclick="ConfirmSave">Save Record</button>
                <button class="action-btn" @onclick="CloseModal">Cancel</button>
            </div>
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon">@(confirmType == "delete" ? "🗑️" : "💾")</div>
            <h3 style="margin-top: 10px;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="action-btn" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(confirmType == "delete" ? "btn-danger-action" : "btn-primary")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "delete" ? "Yes, Delete" : "Yes, Save")
                </button>
            </div>
        </div>
    </div>
}
















@code {
    private bool isChecking = true, hasAccess = false, showModal = false, isEditing = false;
    private string searchTerm = "", orgName = "", errorMsg = "", _conn = DbConfig.ConnectionString;
    private int myOrgId => Login.LoggedInOrgId; private int maxResidents = 0;
    private List<TenantModel> tenants = new(); private TenantModel newTenant = new();

    // Confirmation State
    private bool showConfirmModal = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmType = ""; 
    private int? pendingDeleteId = null;

    protected override async Task OnInitializedAsync() {
        hasAccess = await CheckAccess("Tenants");
        if (hasAccess) await LoadData();
        isChecking = false;
    }

    private async Task LoadData() {
        try {
            tenants.Clear();
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmdOrg = new("SELECT Name, MaxResidents FROM Organizations WHERE OrganizationId = @oid", conn);
            cmdOrg.Parameters.AddWithValue("@oid", myOrgId);
            using var readerOrg = await cmdOrg.ExecuteReaderAsync();
            if (await readerOrg.ReadAsync()) { orgName = readerOrg.GetString(0); maxResidents = readerOrg.GetInt32(1); }
            await readerOrg.CloseAsync();

            string sql = "SELECT Id, FullName, Email, PhoneNumber, UnitNumber, Status FROM Tenants WHERE OrganizationId = @oid ORDER BY FullName";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@oid", myOrgId);
            using var reader = await cmd.ExecuteReaderAsync();
            while (await reader.ReadAsync()) {
                tenants.Add(new TenantModel { Id = reader.GetInt32(0), FullName = reader.GetString(1), Email = reader.IsDBNull(2) ? "" : reader.GetString(2), PhoneNumber = reader.IsDBNull(3) ? "" : reader.GetString(3), UnitNumber = reader.GetString(4), Status = reader.GetString(5) });
            }
        } catch {}
    }
    
    private IEnumerable<TenantModel> FilteredTenants => tenants.Where(t => t.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || t.UnitNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
    private void OpenCreateModal() { isEditing = false; errorMsg = ""; newTenant = new TenantModel { Status = "Active" }; showModal = true; }
    private void OpenEditModal(TenantModel t) { isEditing = true; errorMsg = ""; newTenant = new TenantModel { Id = t.Id, FullName = t.FullName, Email = t.Email, PhoneNumber = t.PhoneNumber, UnitNumber = t.UnitNumber, Status = t.Status }; showModal = true; }
    private void CloseModal() { showModal = false; errorMsg = ""; }

    // --- Confirmation Logic ---

    private void ConfirmSave()
    {
        if (string.IsNullOrWhiteSpace(newTenant.Email)) { errorMsg = "Email is required for login."; return; }
        if (!isEditing && tenants.Count >= maxResidents) { errorMsg = "Resident limit reached."; return; }

        confirmType = "save";
        confirmTitle = isEditing ? "Update Tenant?" : "Add New Tenant?";
        confirmMessage = isEditing 
            ? $"Save changes for {newTenant.FullName}? This will update their directory information." 
            : $"Register {newTenant.FullName} to unit {newTenant.UnitNumber}? They will be able to log in with the default password.";
        showConfirmModal = true;
    }

    private void ConfirmDelete(TenantModel t)
    {
        pendingDeleteId = t.Id;
        confirmType = "delete";
        confirmTitle = "Confirm Deletion";
        confirmMessage = $"Are you sure you want to remove {t.FullName} from the system? This will delete their account access and record permanently.";
        showConfirmModal = true;
    }

    private async Task ExecuteConfirmedAction()
    {
        showConfirmModal = false;
        if (confirmType == "save") await SaveTenant();
        else if (confirmType == "delete" && pendingDeleteId.HasValue) await DeleteTenant(pendingDeleteId.Value);
    }

    // --- Database Operations ---

    private async Task SaveTenant() {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();

            if (!isEditing) {
                using SqlCommand check = new("SELECT COUNT(*) FROM Tenants WHERE Email = @e", conn);
                check.Parameters.AddWithValue("@e", newTenant.Email);
                if ((int)await check.ExecuteScalarAsync() > 0) { errorMsg = "Email already exists."; return; }
            }

            string sql = isEditing 
                ? "UPDATE Tenants SET FullName = @n, Email = @e, PhoneNumber = @p, UnitNumber = @u, Status = @s WHERE Id = @id AND OrganizationId = @oid" 
                : "INSERT INTO Tenants (OrganizationId, FullName, Email, PhoneNumber, UnitNumber, Status, [Password]) VALUES (@oid, @n, @e, @p, @u, @s, 'Tenant123')";
            
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@oid", myOrgId); cmd.Parameters.AddWithValue("@n", newTenant.FullName); 
            cmd.Parameters.AddWithValue("@e", newTenant.Email); cmd.Parameters.AddWithValue("@p", newTenant.PhoneNumber ?? ""); 
            cmd.Parameters.AddWithValue("@u", newTenant.UnitNumber); cmd.Parameters.AddWithValue("@s", newTenant.Status);
            if (isEditing) cmd.Parameters.AddWithValue("@id", newTenant.Id);
            
            await cmd.ExecuteNonQueryAsync(); showModal = false; await LoadData();
        } catch { errorMsg = "Error saving data."; }
    }

    private async Task DeleteTenant(int id) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            using SqlCommand cmd = new("DELETE FROM Tenants WHERE Id = @id AND OrganizationId = @oid", conn);
            cmd.Parameters.AddWithValue("@id", id); cmd.Parameters.AddWithValue("@oid", myOrgId);
            await cmd.ExecuteNonQueryAsync(); await LoadData();
        } catch { }
    }

    private async Task<bool> CheckAccess(string module) {
        try {
            using SqlConnection conn = new(_conn); await conn.OpenAsync();
            string sql = "SELECT su.IsEnabled FROM Organizations o JOIN SystemUpdates su ON o.PlanType = su.PlanType WHERE o.OrganizationId = @oid AND su.ModuleName = @mod";
            using SqlCommand cmd = new(sql, conn); cmd.Parameters.AddWithValue("@oid", myOrgId); cmd.Parameters.AddWithValue("@mod", module);
            var res = await cmd.ExecuteScalarAsync(); return res != null && Convert.ToBoolean(res);
        } catch { return false; }
    }
    public class TenantModel { public int Id { get; set; } public string FullName { get; set; } = ""; public string Email { get; set; } = ""; public string PhoneNumber { get; set; } = ""; public string UnitNumber { get; set; } = ""; public string Status { get; set; } = "Active"; }
}


















<style>
