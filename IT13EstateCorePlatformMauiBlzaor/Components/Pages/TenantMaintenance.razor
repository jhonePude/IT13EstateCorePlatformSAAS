@page "/tenant-maintenance"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using System.Globalization
@using IT13EstateCorePlatformMauiBlzaor.Data
@inject NavigationManager Nav

@if (isChecking)
{
    <p style="padding:40px; text-align:center; font-family:'Inter',sans-serif;">Verifying access...</p>
}
else if (!hasAccess)
{
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1000px; width: 100%; height: auto;" />
    </div>
}
else
{
    <div class="maintenance-container">
        <header class="page-header">
            <div class="header-left">
                <h1>My Maintenance Requests</h1>
                <p class="subtitle">
                    @if (DbConfig.IsOnline) {
                        <span class="conn-tag online"><span class="pulse-dot"></span> Online</span>
                    } else {
                        <span class="conn-tag offline">🌐 Offline</span>
                    }
                    • @Login.LoggedInOrgName • Resident of @unitNumber
                </p>
            </div>

            <div class="header-right-group">
                <label for="tenantPicUpload" class="user-profile-btn">
                    <div class="profile-info" style="text-align: right;">
                        <span class="profile-name">@Login.LoggedInName</span>
                        <span class="profile-role">Resident</span>
                    </div>
                    <div class="avatar-circle">
                        @if (!string.IsNullOrEmpty(profilePicBase64))
                        {
                            <img src="@profilePicBase64" />
                        }
                        else
                        {
                            <span>@(string.IsNullOrEmpty(Login.LoggedInName) ? "T" : Login.LoggedInName.Substring(0, 1).ToUpper())</span>
                        }
                    </div>
                    <InputFile id="tenantPicUpload" OnChange="HandleFileSelected" style="display:none;" />
                </label>
            </div>
        </header>

        <div class="action-bar">
            <div class="search-box">
                <input type="text" placeholder="Search my requests..." @bind="searchTerm" @bind:event="oninput" class="search-input" />
            </div>
            <button class="btn-primary" @onclick="() => showModal = true">+ Create New Request</button>
        </div>

        @if (!FilteredRequests.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">🛠️</span>
                <h3>No maintenance history</h3>
                <p>Submit a request if something in your unit needs repair.</p>
            </div>
        }
        else
        {
            <div class="maintenance-grid">
                @foreach (var req in FilteredRequests)
                {
                    <div class="maintenance-card">
                        <div class="card-top">
                            <div class="title-group" style="display:flex; justify-content:space-between; align-items:start;">
                                <h3 class="card-title">@req.Title</h3>
                                <span class="priority-badge @req.Priority.ToLower()">@req.Priority</span>
                            </div>
                            <span class="request-date">Submitted: @req.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <p class="description">@req.Description</p>
                            <div class="status-indicator @req.Status.Replace(" ", "-").ToLower()">
                                <span class="status-icon">@(req.Status == "PENDING" ? "🕒" : req.Status == "IN PROGRESS" ? "⚙️" : "✅")</span>
                                <span class="status-text">@req.Status</span>
                            </div>
                        </div>
                        
                        <div class="card-footer" style="display:flex; justify-content:space-between; align-items:center; min-height: 45px;">
                            @if (req.Status == "COMPLETED" && req.ResolvedAt.HasValue)
                            {
                                <span class="resolved-note">Resolved on @req.ResolvedAt.Value.ToString("MMM dd, hh:mm tt")</span>
                            }
                            else if (req.Status == "PENDING")
                            {
                                <button class="btn-delete-small" @onclick="() => TriggerCancelConfirm(req)">Cancel Request</button>
                            }
                            else
                            {
                                <span style="font-size: 11px; color: #3b82f6; font-weight:700;">Request is being processed...</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* Create Request Modal *@
@if (showModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <h3>New Maintenance Request</h3>
            <p style="font-size:13px; color:#6b7280; margin-bottom:20px;">Please provide details about the issue in your unit.</p>
            <label>Issue Title</label>
            <input type="text" @bind="newRequest.Title" class="form-input" placeholder="e.g. Leaking Faucet" />
            <label>Description</label>
            <textarea @bind="newRequest.Description" class="form-input" rows="4" placeholder="Describe the problem..."></textarea>
            <label>Priority</label>
            <select @bind="newRequest.Priority" class="form-input">
                <option value="LOW">LOW</option>
                <option value="MEDIUM">MEDIUM</option>
                <option value="HIGH">HIGH</option>
            </select>
            <div style="display:flex; gap:12px; margin-top:10px;">
                <button class="btn-primary" style="flex:1;" @onclick="TriggerSubmitConfirm">Submit</button>
                <button class="btn-outline" style="flex:1;" @onclick="() => showModal = false">Cancel</button>
            </div>
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon">@(confirmType == "cancel" ? "🗑️" : "📤")</div>
            <h3 style="margin-top: 10px; font-weight: 800;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">
                @confirmMessage
            </p>

            <div style="display:flex; gap:12px;">
                <button class="btn-outline" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(confirmType == "cancel" ? "btn-danger-action" : "btn-primary")" 
                        style="flex:1;" @onclick="ExecuteConfirmedAction">
                    @(confirmType == "cancel" ? "Confirm" : "Yes, Submit")
                </button>
            </div>
        </div>
    </div>
}












@code {
    private bool isChecking = true, hasAccess = true, showModal = false;
    private string _conn = DbConfig.ConnectionString, unitNumber = "", searchTerm = "", profilePicBase64 = "";
    private List<MaintenanceModel> myRequests = new();
    private MaintenanceModel newRequest = new() { Priority = "MEDIUM" };

    private bool showConfirmModal = false;
    private string confirmTitle = "", confirmMessage = "", confirmType = "";
    private int? pendingRequestId = null;

    private IEnumerable<MaintenanceModel> FilteredRequests => myRequests.Where(r => string.IsNullOrWhiteSpace(searchTerm) || r.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() {
        if (Login.LoggedInTenantId == null) { Nav.NavigateTo("/login"); return; }
        hasAccess = await CheckModuleAccess("Maintenance");
        if (hasAccess) { 
            await LoadData(); 
            await LoadProfilePic(); 
            // [ RECOVERY SYNC: OFFLINE -> ONLINE ]
            if (DbConfig.IsOnline) { _ = SyncOfflineMaintenance(); }
        }
        isChecking = false;
    }

    private async Task SyncOfflineMaintenance() {
        try {
            using SqlConnection local = new(DbConfig.GetLocalRaw); await local.OpenAsync();
            using var reader = await new SqlCommand($"SELECT Title, Description, Priority, Status, CreatedAt FROM MaintenanceRequests WHERE TenantId = {Login.LoggedInTenantId}", local).ExecuteReaderAsync();
            using SqlConnection online = new(DbConfig.ConnectionString); await online.OpenAsync();
            while (await reader.ReadAsync()) {
                string sql = @"IF NOT EXISTS (SELECT 1 FROM MaintenanceRequests WHERE Title=@t AND TenantId=@tid AND CAST(CreatedAt as smalldatetime) = CAST(@d as smalldatetime))
                               INSERT INTO MaintenanceRequests (OrganizationId, TenantId, Title, Description, Priority, Status, CreatedAt)
                               VALUES (@oid, @tid, @t, @desc, @p, @s, @d)";
                using SqlCommand cmd = new(sql, online);
                cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
                cmd.Parameters.AddWithValue("@t", reader.GetString(0)); cmd.Parameters.AddWithValue("@desc", reader.IsDBNull(1) ? "" : reader.GetString(1));
                cmd.Parameters.AddWithValue("@p", reader.GetString(2)); cmd.Parameters.AddWithValue("@s", reader.GetString(3)); cmd.Parameters.AddWithValue("@d", reader.GetDateTime(4));
                await cmd.ExecuteNonQueryAsync();
            }
        } catch { }
    }

    private async Task<bool> CheckModuleAccess(string mod) {
        try {
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            var res = await new SqlCommand($@"SELECT IsEnabled FROM SystemUpdates su JOIN Organizations o ON su.PlanType = o.PlanType WHERE o.OrganizationId = {Login.LoggedInOrgId} AND su.ModuleName = '{mod}'", conn).ExecuteScalarAsync();
            return res != null && Convert.ToBoolean(res);
        } catch { return false; }
    }

    private async Task LoadData() {
        try {
            myRequests.Clear();
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            unitNumber = (await new SqlCommand($"SELECT UnitNumber FROM Tenants WHERE Id = {Login.LoggedInTenantId}", conn).ExecuteScalarAsync())?.ToString() ?? "N/A";
            using var reader = await new SqlCommand($@"SELECT Id, Title, Description, Priority, Status, CreatedAt, ResolvedAt FROM MaintenanceRequests WHERE TenantId = {Login.LoggedInTenantId} ORDER BY CreatedAt DESC", conn).ExecuteReaderAsync();
            while (await reader.ReadAsync()) myRequests.Add(new MaintenanceModel { Id = reader.GetInt32(0), Title = reader.GetString(1), Description = reader.IsDBNull(2) ? "" : reader.GetString(2), Priority = reader.GetString(3), Status = reader.GetString(4), CreatedAt = reader.GetDateTime(5), ResolvedAt = reader.IsDBNull(6) ? null : reader.GetDateTime(6) });
        } catch { }
    }

    private void TriggerSubmitConfirm() { if (string.IsNullOrWhiteSpace(newRequest.Title)) return; confirmType = "submit"; confirmTitle = "Submit Request?"; confirmMessage = "Broadcast to cloud database?"; showConfirmModal = true; }
    private void TriggerCancelConfirm(MaintenanceModel req) { pendingRequestId = req.Id; confirmType = "cancel"; confirmTitle = "Withdraw Request?"; confirmMessage = "Remove from all databases?"; showConfirmModal = true; }

    private async Task ExecuteConfirmedAction() {
        showConfirmModal = false;
        string sql = confirmType == "submit" ? "INSERT INTO MaintenanceRequests (OrganizationId, TenantId, Title, Description, Priority, Status, CreatedAt) VALUES (@oid, @tid, @title, @desc, @priority, 'PENDING', GETDATE())" 
                                              : "DELETE FROM MaintenanceRequests WHERE Id = @id AND TenantId = @tid AND Status = 'PENDING'";
        // --- [ DUAL WRITE ] ---
        await RunSqlDual(sql);
        showModal = false; newRequest = new MaintenanceModel { Priority = "MEDIUM" }; await LoadData();
    }

    private async Task RunSqlDual(string sql) {
        await ExecuteSingleSql(DbConfig.GetLocalRaw, sql);
        if (DbConfig.IsOnline) { await ExecuteSingleSql(DbConfig.ConnectionString, sql); }
    }

    private async Task ExecuteSingleSql(string cs, string sql) {
        try {
            using SqlConnection conn = new(cs); await conn.OpenAsync();
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId); cmd.Parameters.AddWithValue("@tid", Login.LoggedInTenantId);
            cmd.Parameters.AddWithValue("@title", newRequest.Title ?? ""); cmd.Parameters.AddWithValue("@desc", newRequest.Description ?? "");
            cmd.Parameters.AddWithValue("@priority", newRequest.Priority ?? "MEDIUM");
            if (pendingRequestId.HasValue) cmd.Parameters.AddWithValue("@id", pendingRequestId.Value);
            await cmd.ExecuteNonQueryAsync();
        } catch { }
    }

    private async Task LoadProfilePic() {
        using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
        profilePicBase64 = (await new SqlCommand($"SELECT ProfilePicture FROM Tenants WHERE Id = {Login.LoggedInTenantId}", conn).ExecuteScalarAsync())?.ToString() ?? "";
    }
    private async Task HandleFileSelected(InputFileChangeEventArgs e) { /* logic as previously established */ }
    public class MaintenanceModel { public int Id; public string Title="", Description="", Priority="", Status=""; public DateTime CreatedAt; public DateTime? ResolvedAt; }
}
















<style>
    /* Connection Tag Style */
    .conn-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; font-size: 13px; color: #10b981; }
    .conn-tag.offline { color: #6b7280; }
    .pulse-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; position: relative; }
    .pulse-dot::after { content: ""; position: absolute; top:0; left:0; right:0; bottom:0; background: inherit; border-radius: 50%; animation: pulse-main-t-sync 1.5s infinite; }
    @@keyframes pulse-main-t-sync { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

    /* RESTORED ORIGINAL CSS */
    .maintenance-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .header-left h1 { font-size: 32px; font-weight: 800; color: #111827; margin: 0; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }
    .user-profile-btn { display: flex; align-items: center; gap: 12px; cursor: pointer; padding: 8px 15px; border-radius: 12px; background: white; border: 1px solid #e5e7eb; }
    .avatar-circle { width: 42px; height: 42px; background: #111827; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; border: 2px solid #d4af37; overflow: hidden;}
    .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
    .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .search-input { padding: 12px 16px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; width: 300px; outline: none; background: white; }
    .btn-primary { background: #111827; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; font-size: 14px; }
    .maintenance-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .maintenance-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; display: flex; flex-direction: column; transition: 0.2s; }
    .card-top { padding: 20px; flex-grow: 1; }
    .card-title { font-size: 16px; font-weight: 700; color: #111827; margin: 0; }
    .priority-badge { font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 50px; text-transform: uppercase; }
    .priority-badge.low { background: #f1f5f9; color: #64748b; }
    .priority-badge.medium { background: #111827; color: white; }
    .priority-badge.high { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
    .card-footer { padding: 12px 20px; background: #f9fafb; border-top: 1px solid #f3f4f6; border-radius: 0 0 12px 12px; }
    .btn-delete-small { background: #fee2e2; color: #dc2626; border: none; padding: 6px 12px; border-radius: 6px; font-size: 11px; font-weight: 700; }
    .empty-state { text-align: center; padding: 80px; background: white; border: 1px dashed #e5e7eb; border-radius: 16px; color: #9ca3af; grid-column: 1 / -1; }
    .empty-icon { font-size: 48px; display: block; margin-bottom: 15px; }
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 9000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .form-input { width: 100%; padding: 12px; margin: 8px 0 18px 0; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; }
    .btn-outline { background: white; border: 1px solid #e5e7eb; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer; }
    .btn-danger-action { background: #dc2626; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 700; }
</style>