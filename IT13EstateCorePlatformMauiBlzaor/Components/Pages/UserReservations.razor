@page "/admin-reservations"
@layout UserLayout
@using System.Data
@using Microsoft.Data.SqlClient
@using IT13EstateCorePlatformMauiBlzaor.Data

@if (isChecking)
{
    <p style="padding:40px;">Verifying module access...</p>
}
else if (!hasAccess)
{
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 0vh; text-align: center;">
        <img src="Maintenance.png" alt="Under Maintenance" style="max-width: 1100px; width: 100%; height: 80%; margin-top: -100px;" />
    </div>
}
else
{
    <div class="page-container">
        <header class="page-header">
            <div class="header-left">
                <h1>Reservations</h1>
                <p class="subtitle">
                    @if (DbConfig.IsOnline) {
                        <span class="conn-tag online"><span class="pulse-dot"></span> Online</span>
                    } else {
                        <span class="conn-tag offline">🌐 Offline</span>
                    }
                    • Manage facility bookings for: <strong>@orgName</strong>
                </p>
            </div>
        </header>

        <div class="main-card">
            <div class="card-header-flex">
                <h2 class="card-title">All Reservation Requests</h2>
                <div class="search-box">
                    <input type="text" placeholder="Search resident or facility..." 
                           class="search-input" 
                           @bind="searchTerm" 
                           @bind:event="oninput" />
                </div>
            </div>

            @if (FilteredReservations.Count() == 0)
            {
                <div style="text-align:center; padding:40px; color:gray;">
                    <p>No reservations found matching your search.</p>
                </div>
            }
            else
            {
                <div class="reservation-list">
                    @foreach (var res in FilteredReservations)
                    {
                        <div class="reservation-item">
                            <div class="item-left">
                                <div class="icon-square">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                    </svg>
                                </div>
                                <div class="item-details">
                                    <div class="name-status">
                                        <span class="facility-name">@res.FacilityName</span>
                                        <span class="status-badge @res.Status.ToLower()">@res.Status</span>
                                    </div>
                                    <div class="meta-info">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> @res.ReservationDate.ToString("MM/dd/yyyy, hh:mm tt")
                                    </div>
                                    <div class="resident-info">
                                        Resident: @(string.IsNullOrEmpty(res.TenantName) ? "Unknown (Syncing...)" : res.TenantName) • @res.UnitNumber
                                    </div>
                                </div>
                            </div>
                            <div class="item-actions">
                                @if (res.Status == "PENDING")
                                {
                                    <button class="btn-accept" @onclick='() => TriggerConfirm(res, "CONFIRMED")'>Accept</button>
                                    <button class="btn-reject" @onclick='() => TriggerConfirm(res, "REJECTED")'>Reject</button>
                                }
                                else
                                {
                                    @* DESIGN RESTORED: Uses the gray btn-cancel style for Reset *@
                                    <button class="btn-cancel" @onclick='() => TriggerConfirm(res, "PENDING")'>Reset to Pending</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@* CUSTOM CONFIRMATION MODAL *@
@if (showConfirmModal)
{
    <div class="modal-backdrop" style="z-index: 10000;">
        <div class="modal-content" style="width: 400px; text-align: center;">
            <div class="confirm-icon">
                @if (pendingStatus == "CONFIRMED")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                }
                else if (pendingStatus == "REJECTED")
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                }
            </div>
            <h3 style="margin-top: 10px; font-weight: 800;">@confirmTitle</h3>
            <p style="font-size:14px; color:#6b7280; margin: 15px 0 25px 0; line-height: 1.5;">@confirmMessage</p>

            <div style="display:flex; gap:12px;">
                <button class="btn-cancel-modal" style="flex:1;" @onclick="() => showConfirmModal = false">Cancel</button>
                <button class="@(pendingStatus == "CONFIRMED" ? "btn-accept" : pendingStatus == "REJECTED" ? "btn-reject-confirm" : "btn-primary-confirm")" 
                        style="flex:1;" @onclick="ExecuteConfirmedUpdate">
                    Confirm Action
                </button>
            </div>
        </div>
    </div>
}









@code {
    private bool isChecking = true, hasAccess = false, showConfirmModal = false;
    private string searchTerm = "", orgName = "", confirmTitle = "", confirmMessage = "", pendingStatus = "";
    private int pendingReservationId = 0;
    private List<ReservationModel> reservations = new();
    private int myOrgId => Login.LoggedInOrgId;

    private IEnumerable<ReservationModel> FilteredReservations =>
        reservations.Where(r => r.FacilityName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                (r.TenantName != null && r.TenantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync() {
        hasAccess = await CheckAccess("Reservations");
        if (hasAccess) {
            await LoadData();
            // --- [ RECOVERY SYNC LOOP: OFFLINE -> ONLINE ] ---
            if (DbConfig.IsOnline) { _ = SyncMissingData(); }
        }
        isChecking = false;
    }

    private async Task SyncMissingData() {
        try {
            using SqlConnection local = new(DbConfig.GetLocalRaw); await local.OpenAsync();
            // Loop local and push anything missing from cloud mirror
            using var reader = await new SqlCommand($"SELECT TenantId, FacilityName, ReservationDate, Status FROM Reservations WHERE OrganizationId = {myOrgId}", local).ExecuteReaderAsync();
            using SqlConnection online = new(DbConfig.ConnectionString); await online.OpenAsync();
            while (await reader.ReadAsync()) {
                string sqlSync = @"IF NOT EXISTS (SELECT 1 FROM Reservations WHERE TenantId=@tid AND CAST(ReservationDate as smalldatetime) = CAST(@d as smalldatetime) AND FacilityName=@f)
                                   INSERT INTO Reservations (OrganizationId, TenantId, FacilityName, ReservationDate, Status, CreatedAt)
                                   VALUES (@oid, @tid, @f, @d, @s, GETDATE())";
                using SqlCommand cmd = new(sqlSync, online);
                cmd.Parameters.AddWithValue("@oid", myOrgId); cmd.Parameters.AddWithValue("@tid", reader.GetInt32(0));
                cmd.Parameters.AddWithValue("@f", reader.GetString(1)); cmd.Parameters.AddWithValue("@d", reader.GetDateTime(2));
                cmd.Parameters.AddWithValue("@s", reader.GetString(3));
                await cmd.ExecuteNonQueryAsync();
            }
        } catch { }
    }

    private async Task LoadData() {
        try {
            reservations.Clear();
            using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
            orgName = (await new SqlCommand($"SELECT Name FROM Organizations WHERE OrganizationId = {myOrgId}", conn).ExecuteScalarAsync())?.ToString() ?? "Unknown";

            // LEFT JOIN ensures we see local data requests even if Tenant row hasn't synced to cloud mirror yet
            string sql = $@"SELECT r.Id, r.FacilityName, r.ReservationDate, r.Status, t.FullName, t.UnitNumber 
                           FROM Reservations r LEFT JOIN Tenants t ON r.TenantId = t.Id WHERE r.OrganizationId = {myOrgId}
                           ORDER BY CASE WHEN r.Status = 'PENDING' THEN 1 ELSE 2 END, r.ReservationDate ASC";
            
            using var reader = await new SqlCommand(sql, conn).ExecuteReaderAsync();
            while (await reader.ReadAsync()) {
                reservations.Add(new ReservationModel {
                    Id = reader.GetInt32(0),
                    FacilityName = reader.GetString(1),
                    ReservationDate = reader.GetDateTime(2),
                    Status = reader.GetString(3),
                    TenantName = reader.IsDBNull(4) ? "" : reader.GetString(4),
                    UnitNumber = reader.IsDBNull(5) ? "N/A" : reader.GetString(5)
                });
            }
        } catch { }
    }

    private void TriggerConfirm(ReservationModel res, string nextStatus) {
        pendingReservationId = res.Id; pendingStatus = nextStatus; showConfirmModal = true;
        if (nextStatus == "CONFIRMED") { confirmTitle = "Approve Booking?"; confirmMessage = $"Accept {res.FacilityName} for {res.TenantName}?"; }
        else if (nextStatus == "REJECTED") { confirmTitle = "Reject Booking?"; confirmMessage = $"Decline {res.FacilityName}?"; }
        else { confirmTitle = "Reset Request?"; confirmMessage = "Revert status to Pending?"; }
    }

    private async Task ExecuteConfirmedUpdate() {
        showConfirmModal = false;
        // --- [ DUAL WRITE ] ---
        await RunUpdateSql(DbConfig.GetLocalRaw);
        if (DbConfig.IsOnline) { await RunUpdateSql(DbConfig.ConnectionString); }
        await LoadData();
    }

    private async Task RunUpdateSql(string cs) {
        try {
            using SqlConnection conn = new(cs); await conn.OpenAsync();
            using SqlCommand cmd = new("UPDATE Reservations SET Status = @s WHERE Id = @id AND OrganizationId = @oid", conn);
            cmd.Parameters.AddWithValue("@s", pendingStatus); cmd.Parameters.AddWithValue("@id", pendingReservationId);
            cmd.Parameters.AddWithValue("@oid", myOrgId);
            await cmd.ExecuteNonQueryAsync();
        } catch { }
    }

    private async Task<bool> CheckAccess(string m) {
        using SqlConnection conn = new(DbConfig.ConnectionString); await conn.OpenAsync();
        var res = await new SqlCommand($"SELECT IsEnabled FROM SystemUpdates su JOIN Organizations o ON su.PlanType = o.PlanType WHERE o.OrganizationId = {myOrgId} AND su.ModuleName = '{m}'", conn).ExecuteScalarAsync();
        return res != null && Convert.ToBoolean(res);
    }
    public class ReservationModel { public int Id; public string FacilityName="", Status="", TenantName="", UnitNumber=""; public DateTime ReservationDate; }
}







<style>
    /* Connection Pulsating Status */
    .conn-tag { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; font-size: 13px; color: #10b981; }
    .conn-tag.offline { color: #6b7280; }
    .pulse-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; position: relative; }
    .pulse-dot::after { content: ""; position: absolute; top:0; left:0; right:0; bottom:0; background: inherit; border-radius: 50%; animation: pulse-res-anim 1.5s infinite; }
    @@keyframes pulse-res-anim { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

    /* RESTORED ORIGINAL CSS */
    .page-container { padding: 40px; background-color: #f8f9fa; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .page-header h1 { font-size: 32px; font-weight: 800; color: #111827; }
    .subtitle { color: #6b7280; font-size: 14px; margin-top: 5px; }
    .main-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; }
    .card-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .card-title { font-size: 14px; font-weight: 700; color: #111827; margin: 0; text-transform: uppercase; }
    .search-input { padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; width: 250px; }
    .reservation-list { display: flex; flex-direction: column; gap: 12px; }
    .reservation-item { display: flex; justify-content: space-between; align-items: center; padding: 16px; border: 1px solid #f3f4f6; border-radius: 10px; }
    .icon-square { width: 44px; height: 44px; background: #f3f4f6; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
    .facility-name { font-weight: 700; font-size: 15px; color: #111827; }
    .status-badge { font-size: 10px; font-weight: 800; padding: 4px 12px; border-radius: 100px; text-transform: uppercase; }
    .status-badge.confirmed { background: #111827; color: white; }
    .status-badge.pending { background: #fef3c7; color: #d97706; }
    .status-badge.rejected { background: #fee2e2; color: #dc2626; }
    .resident-info { font-size: 13px; color: #374151; font-weight: 600; }
    .meta-info { font-size: 13px; color: #6b7280; display: flex; align-items: center; gap: 6px; }

    /* Action Buttons Design Restored */
    .btn-accept { background: #10b981; color: white; border: none; padding: 8px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.2s; }
    .btn-accept:hover { background: #059669; }

    .btn-reject { background: #fee2e2; color: #dc2626; border: none; padding: 8px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.2s; }
    .btn-reject:hover { background: #fecaca; }

    .btn-cancel { background: #f3f4f6; color: #6b7280; border: 1px solid #e5e7eb; padding: 8px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.2s; }
    .btn-cancel:hover { background: #e5e7eb; color: #111827; }

    .btn-reject-confirm { background: #dc2626; color: white; border: none; padding: 10px; border-radius: 8px; font-weight: 600; }
    .btn-primary-confirm { background: #111827; color: white; border: none; padding: 10px; border-radius: 8px; font-weight: 600; }
    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 9000; }
    .modal-content { background: white; padding: 35px; border-radius: 16px; width: 450px; }
    .btn-cancel-modal { background: white; border: 1px solid #e5e7eb; padding: 10px; border-radius: 8px; font-weight: 600; }
</style>