@using Microsoft.Data.SqlClient
@using IT13EstateCorePlatformMauiBlzaor.Data
@inject NavigationManager Navigation

<nav class="sidenav">
    <div class="sidenav-header">
        <div class="logo-container">
            <img src="logo.png" alt="Estate Core Platform Logo" class="nav-logo" />
            <div class="brand-text-container">
                <span class="brand-name">Estate Core</span>
                <span class="brand-platform">Platform</span>
                <span class="brand-tagline">Unified Community & Estate Management</span>
            </div>
        </div>
    </div>

    <div class="nav-scroll-area">
        @* --- 1. SUPER ADMIN SECTION --- *@
        @if (Login.LoggedInRole == "SuperAdmin")
        {
            <div class="nav-section">
                <span class="nav-section-title">Main</span>
                <NavLink href="/super-dashboard" class="nav-item" ActiveClass="active" Match="NavLinkMatch.All">
                    <span class="nav-icon">◎</span>
                    <span class="nav-text">Dashboard</span>
                </NavLink>
                <NavLink href="/super-organizations" class="nav-item" ActiveClass="active">
                    <span class="nav-icon">⌂</span>
                    <span class="nav-text">Organizations</span>
                </NavLink>
                <NavLink href="/super-system-updates" class="nav-item" ActiveClass="active">
                    <span class="nav-icon">⚙</span>
                    <span class="nav-text">System Updates</span>
                </NavLink>
            </div>
        }

        @* --- 2. ADMIN SECTION (Plan-based hiding) --- *@
        else if (Login.LoggedInRole == "Admin")
        {
            <div class="nav-section">
                <span class="nav-section-title">Overview</span>
                @if (IsModuleEnabled("Dashboard"))
                {
                    <NavLink href="/admin-dashboard" class="nav-item" ActiveClass="active" Match="NavLinkMatch.All">
                        <span class="nav-icon">📊</span>
                        <span class="nav-text">Dashboard</span>
                    </NavLink>
                }
            </div>

            <div class="nav-section">
                <span class="nav-section-title">Management</span>
                @if (IsModuleEnabled("Tenants"))
                {
                    <NavLink href="/admin-tenants" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">👥</span>
                        <span class="nav-text">Tenants</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Billing"))
                {
                    <NavLink href="/admin-billing" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">💳</span>
                        <span class="nav-text">Billing & Payments</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Maintenance"))
                {
                    <NavLink href="/admin-maintenance" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">🔧</span>
                        <span class="nav-text">Maintenance</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Reservations"))
                {
                    <NavLink href="/admin-reservations" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">📅</span>
                        <span class="nav-text">Reservations</span>
                    </NavLink>
                }
            </div>

            <div class="nav-section">
                <span class="nav-section-title">Analytics</span>
                @if (IsModuleEnabled("Reports"))
                {
                    <NavLink href="/admin-reports" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">📈</span>
                        <span class="nav-text">Reports</span>
                    </NavLink>
                }
            </div>

            <div class="nav-section">
                <span class="nav-section-title">Communication</span>
                @if (IsModuleEnabled("Announcements"))
                {
                    <NavLink href="/admin-announcements" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">📢</span>
                        <span class="nav-text">Announcements</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Feedback"))
                {
                    <NavLink href="/admin-promos" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">⭐</span>
                        <span class="nav-text">Feedback & Promos</span>
                    </NavLink>
                }
            </div>
        }

        @* --- 3. TENANT SECTION (Plan-based hiding) --- *@
        else if (Login.LoggedInRole == "Tenant")
        {
            <div class="nav-section">
                <span class="nav-section-title">Resident Portal</span>
                @if (IsModuleEnabled("Dashboard"))
                {
                    <NavLink href="/tenant-dashboard" class="nav-item" ActiveClass="active" Match="NavLinkMatch.All">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-text">Dashboard</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Billing"))
                {
                    <NavLink href="/tenant-billing" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">💳</span>
                        <span class="nav-text">Billing & Payments</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Maintenance"))
                {
                    <NavLink href="/tenant-maintenance" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">🔧</span>
                        <span class="nav-text">Maintenance</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Reservations"))
                {
                    <NavLink href="/tenant-reservations" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">📅</span>
                        <span class="nav-text">Reservations</span>
                    </NavLink>
                }
                @if (IsModuleEnabled("Feedback"))
                {
                    <NavLink href="/tenant-promos" class="nav-item" ActiveClass="active">
                        <span class="nav-icon">🏷️</span>
                        <span class="nav-text">Feedback & Promos</span>
                    </NavLink>
                }
            </div>
        }
    </div>

    <div class="nav-section nav-section-bottom">
        <button class="nav-item logout-link" @onclick="HandleLogout" style="background:none; border:none; width:100%; text-align:left; cursor:pointer;">
            <span class="nav-icon">↪</span>
            <span class="nav-text">Logout</span>
        </button>
    </div>
</nav>

@code {
    private List<string> EnabledModules = new();
    private string _conn = DbConfig.ConnectionString;

    protected override async Task OnInitializedAsync()
    {
        await LoadModuleAccess();
    }

    private async Task LoadModuleAccess()
    {
        try
        {
            EnabledModules.Clear();
            using SqlConnection conn = new(_conn);
            await conn.OpenAsync();

            // Note: SuperAdmin has LoggedInOrgId = 0 usually, so this query won't affect them.
            string sql = @"SELECT su.ModuleName FROM SystemUpdates su 
                           JOIN Organizations o ON su.PlanType = o.PlanType 
                           WHERE o.OrganizationId = @oid AND su.IsEnabled = 1";
            using SqlCommand cmd = new(sql, conn);
            cmd.Parameters.AddWithValue("@oid", Login.LoggedInOrgId);
            using var r = await cmd.ExecuteReaderAsync();
            while (await r.ReadAsync())
            {
                EnabledModules.Add(r.GetString(0));
            }
        }
        catch { }
    }

    private bool IsModuleEnabled(string moduleName) 
    {
        // SuperAdmin can see everything
        if (Login.LoggedInRole == "SuperAdmin") return true;
        return EnabledModules.Contains(moduleName);
    }

    private void HandleLogout()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}













<style>
